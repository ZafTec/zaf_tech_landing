# Copy this file to `.env` and fill in real values. `.env` is gitignored;
# `.env.example` is checked in so anyone setting up the project knows what's needed.

# ---------------------------------------------------------------------------
# Database — used by the public form endpoints (Bun's SQL driver) AND by
# BetterAuth (pg Pool). Both can share the same Postgres database.
# Format: postgres://user:password@host:port/dbname
# ---------------------------------------------------------------------------
DATABASE_URL=postgres://user:password@host:5432/dbname

# ---------------------------------------------------------------------------
# BetterAuth — admin sign-in + MCP OAuth provider.
# baseURL drives the Google OAuth callback URL the SDK builds.
# secret signs sessions; rotate to invalidate every active admin session.
#   openssl rand -base64 32
# ---------------------------------------------------------------------------
BETTER_AUTH_URL=http://localhost:4321
BETTER_AUTH_SECRET=replace-with-a-long-random-string

# ---------------------------------------------------------------------------
# Google OAuth — passed straight to BetterAuth's social provider.
# Authorized redirect URI in Google Cloud Console must be:
#   <BETTER_AUTH_URL>/api/auth/callback/google
# See docs/admin-setup/README.md for the walkthrough.
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# ---------------------------------------------------------------------------
# SMTP — admin "Reach out" feature and MCP send_reachout tool.
# Leave SMTP_FROM empty to default to SMTP_USER.
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=app-password
SMTP_FROM="ZafTech <hello@zaftech.co>"

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------

# First admin seeded into the `admins` table on first startup.
# Defaults to contact@zaftech.co.
# ADMIN_SEED_EMAIL=contact@zaftech.co

# Google Analytics property ID. Leave unset to disable analytics + the
# consent banner entirely.
# PUBLIC_GA_ID=G-XXXXXXXXXX
