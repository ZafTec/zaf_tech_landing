# Copy this file to `.env` and fill in real values. `.env` is gitignored;
# `.env.example` is checked in so anyone setting up the project knows what's needed.

# ---------------------------------------------------------------------------
# Google OAuth — admin console sign-in
# Create credentials at https://console.cloud.google.com/apis/credentials.
# See docs/admin-setup/README.md for the full walkthrough.
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# 32 random bytes — signs the admin session cookie. Rotating this invalidates
# every existing admin session. Generate with:
#   openssl rand -base64 32
ADMIN_SESSION_SECRET=replace-with-a-long-random-string

# ---------------------------------------------------------------------------
# Database — Bun's SQL driver. Used by contact / careers / audit forms and
# the admin console.
# Format: postgres://user:password@host:port/dbname
# ---------------------------------------------------------------------------
DATABASE_URL=postgres://user:password@host:5432/dbname

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------

# First admin seeded into the `admins` table on first startup.
# Defaults to contact@zaftech.co.
# ADMIN_SEED_EMAIL=contact@zaftech.co

# Override the Google OAuth redirect URI if your dev origin differs from
# what Google calls back to. Otherwise it's inferred from the incoming request.
# GOOGLE_REDIRECT_URI=http://localhost:4321/api/admin/auth/callback

# Google Analytics property ID. Leave unset to disable analytics + the
# consent banner entirely.
# PUBLIC_GA_ID=G-XXXXXXXXXX
