---
import Layout from "@/layouts/Layout.astro";
import SeoHead from "@/components/SeoHead.astro";
import { guardAdminPage } from "@/lib/admin/auth";
import { SEED_EMAIL, listAdmins } from "@/lib/admin/admins";

export const prerender = false;

const gate = await guardAdminPage(Astro);
if (gate instanceof Response) return gate;
const admin = gate;

const admins = await listAdmins();

const title = "Admins · ZafTech Admin";
const description = "Manage who can access the admin console.";

const fmtDate = (iso: string) => {
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso;
  const pad = (n: number) => String(n).padStart(2, "0");
  return `${d.getUTCFullYear()}-${pad(d.getUTCMonth() + 1)}-${pad(d.getUTCDate())}`;
};
---
<Layout title={title} description={description}>
  <Fragment slot="head">
    <SeoHead title={title} description={description} noindex={true} canonicalPath="/admin/admins" />
  </Fragment>

  <div class="min-h-screen flex flex-col bg-onyx-950">
    <header class="border-b border-onyx-800 sticky top-0 z-30 bg-onyx-950/95 backdrop-blur-sm">
      <div class="max-w-7xl mx-auto px-6 md:px-12 py-3 flex items-center justify-between gap-4">
        <div class="flex items-center gap-6">
          <a href="/admin" class="flex items-center gap-3" aria-label="ZafTech Admin">
            <picture>
              <source srcset="/logo/ZAFTECH_LOGO_Square_bgremoved_dark_theme.png" media="(prefers-color-scheme: light)" />
              <img src="/logo/ZAFTECH_LOGO_Square_bgremoved_light_theme.png" alt="ZafTech" class="h-9 w-auto" width="36" height="36" draggable="false" />
            </picture>
            <span class="hidden sm:inline font-mono text-[10px] uppercase tracking-widest text-spruce-400">ZafTech <span class="text-onyx-500">// admin</span></span>
          </a>
          <nav class="hidden md:flex items-center gap-5" aria-label="Admin navigation">
            <a href="/admin" class="text-[10px] font-mono uppercase tracking-widest text-onyx-400 hover:text-spruce-400 transition-colors">Submissions</a>
            <a href="/admin/admins" class="text-[10px] font-mono uppercase tracking-widest text-spruce-400" aria-current="page">Admins</a>
            <a href="/admin/mcp" class="text-[10px] font-mono uppercase tracking-widest text-onyx-400 hover:text-spruce-400 transition-colors">MCP</a>
          </nav>
        </div>
        <div class="flex items-center gap-4">
          <span class="hidden sm:inline font-mono text-[10px] uppercase tracking-widest text-onyx-400">{admin.email}</span>
          <button type="button" class="btn-ghost h-9 px-4" data-signout>Sign out</button>
        </div>
      </div>
    </header>

    <main class="grow">
      <section class="px-6 md:px-12 pt-10 pb-6 max-w-4xl mx-auto w-full">
        <p class="kicker"><span class="text-onyx-500 mr-1">// 02</span><span>Access control</span></p>
        <h1 class="mt-3 display-tight text-3xl md:text-4xl font-medium text-ivory-100">Admins</h1>
        <p class="mt-4 text-[14px] text-onyx-300 leading-relaxed max-w-2xl">
          Anyone in this list can sign in with their Google account and access the admin console. Removing an email
          revokes access immediately — their next request will be redirected to login.
        </p>
      </section>

      <section class="px-6 md:px-12 max-w-4xl mx-auto w-full pb-16">
        <!-- Add admin -->
        <form
          id="admin-add"
          class="border border-onyx-800 bg-onyx-950 p-6"
          data-admin-add
          novalidate
        >
          <p class="font-mono text-[10px] uppercase tracking-widest text-spruce-400">Add admin</p>
          <div class="mt-4 flex flex-col sm:flex-row gap-3">
            <label class="grow">
              <span class="sr-only">Email address</span>
              <input
                type="email"
                name="email"
                required
                placeholder="email@example.com"
                autocomplete="off"
                class="w-full bg-onyx-900 border border-onyx-800 text-ivory-100 placeholder-onyx-500/60 px-4 py-3"
              />
            </label>
            <button type="submit" class="btn-primary sm:w-auto">
              Add admin
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
            </button>
          </div>
          <p class="mt-3 font-mono text-[10px] uppercase tracking-widest text-onyx-500" data-admin-status>
            They must sign in with this exact Google account.
          </p>
        </form>

        <!-- List -->
        <div class="mt-8 border border-onyx-800 bg-onyx-950" data-admin-list-wrap>
          <div class="overflow-x-auto">
            <table class="w-full text-left" data-admin-list>
              <thead>
                <tr class="border-b border-onyx-700">
                  <th class="font-mono text-[10px] uppercase tracking-widest text-spruce-400 px-4 py-3">Email</th>
                  <th class="font-mono text-[10px] uppercase tracking-widest text-spruce-400 px-4 py-3">Added by</th>
                  <th class="font-mono text-[10px] uppercase tracking-widest text-spruce-400 px-4 py-3 whitespace-nowrap">Created</th>
                  <th class="font-mono text-[10px] uppercase tracking-widest text-spruce-400 px-4 py-3"></th>
                </tr>
              </thead>
              <tbody>
                {admins.map((a) => {
                  const isSeed = a.email === SEED_EMAIL;
                  const isSelf = a.email === admin.email;
                  const locked = isSeed || isSelf;
                  return (
                    <tr class="border-b border-onyx-800" data-email={a.email}>
                      <td class="px-4 py-3 text-[14px] text-ivory-100 font-medium">
                        {a.email}
                        {isSeed && <span class="ml-2 font-mono text-[9px] uppercase tracking-widest text-spruce-400">seed</span>}
                        {isSelf && !isSeed && <span class="ml-2 font-mono text-[9px] uppercase tracking-widest text-onyx-400">you</span>}
                      </td>
                      <td class="px-4 py-3 text-[13px] text-onyx-300">{a.added_by ?? "—"}</td>
                      <td class="px-4 py-3 font-mono text-[11px] text-onyx-400 whitespace-nowrap">{fmtDate(a.created_at)}</td>
                      <td class="px-4 py-3 text-right">
                        {locked ? (
                          <span class="font-mono text-[10px] uppercase tracking-widest text-onyx-500">locked</span>
                        ) : (
                          <button
                            type="button"
                            class="btn-ghost h-8 px-3 text-[10px]"
                            data-remove
                            data-email={a.email}
                          >
                            Remove
                          </button>
                        )}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
          {admins.length === 0 && (
            <div class="p-8 text-center font-mono text-[10px] uppercase tracking-widest text-onyx-500">
              // no admins yet
            </div>
          )}
        </div>
      </section>
    </main>

    <footer class="border-t border-onyx-800 mt-auto">
      <div class="max-w-7xl mx-auto px-6 md:px-12 py-5 font-mono text-[10px] uppercase tracking-widest text-onyx-500 flex flex-col sm:flex-row gap-2 sm:items-center sm:justify-between">
        <span>ZafTech admin · internal</span>
        <span><a href="/" class="hover:text-spruce-400 transition-colors">back to zaftech.co</a></span>
      </div>
    </footer>
  </div>

  <script>
    import { createAuthClient } from "better-auth/client";
    const authClient = createAuthClient();
    document.querySelector("[data-signout]")?.addEventListener("click", async () => {
      await authClient.signOut();
      window.location.href = "/admin/login";
    });
  </script>

  <script is:inline>
    (function () {
      const form = document.querySelector("[data-admin-add]");
      const status = document.querySelector("[data-admin-status]");
      const list = document.querySelector("[data-admin-list]");
      if (!form || !status || !list) return;

      const setStatus = (text, tone) => {
        status.textContent = text;
        status.classList.remove("text-spruce-400", "text-red-400");
        if (tone === "ok") status.classList.add("text-spruce-400");
        if (tone === "err") status.classList.add("text-red-400");
      };

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const data = Object.fromEntries(new FormData(e.target));
        const email = String(data.email || "").trim();
        if (!email) return;
        setStatus("Adding...", null);
        try {
          const res = await fetch("/api/admin/admins", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email }),
          });
          const body = await res.json();
          if (!res.ok || !body.ok) {
            setStatus(body.error ? `Failed: ${body.error}` : "Failed to add admin", "err");
            return;
          }
          setStatus(`Added ${email}. They can sign in now.`, "ok");
          e.target.reset();
          window.setTimeout(() => window.location.reload(), 600);
        } catch (err) {
          setStatus("Request failed. Check the console.", "err");
        }
      });

      list.addEventListener("click", async (e) => {
        const target = e.target instanceof Element ? e.target.closest("[data-remove]") : null;
        if (!target) return;
        const email = target.getAttribute("data-email");
        if (!email) return;
        if (!window.confirm(`Remove admin access for ${email}?`)) return;
        target.setAttribute("disabled", "true");
        target.textContent = "Removing…";
        try {
          const res = await fetch("/api/admin/admins", {
            method: "DELETE",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email }),
          });
          const body = await res.json();
          if (!res.ok || !body.ok) {
            setStatus(body.error ? `Failed: ${body.error}` : "Remove failed", "err");
            target.removeAttribute("disabled");
            target.textContent = "Remove";
            return;
          }
          const row = target.closest("tr");
          if (row && row.parentNode) row.parentNode.removeChild(row);
          setStatus(`Removed ${email}.`, "ok");
        } catch (err) {
          setStatus("Request failed. Check the console.", "err");
          target.removeAttribute("disabled");
          target.textContent = "Remove";
        }
      });
    })();
  </script>
</Layout>
