---
import Layout from "@/layouts/Layout.astro";
import SeoHead from "@/components/SeoHead.astro";
import { requireAdmin } from "@/lib/admin/auth";

export const prerender = false;

const existing = await requireAdmin(Astro);
if (existing) {
  return Astro.redirect("/admin");
}

const url = new URL(Astro.request.url);
const error = url.searchParams.get("error");
const email = url.searchParams.get("email");

const errorMessages: Record<string, string> = {
  not_admin: email
    ? `${email} is not on the admin list. Ask an existing admin to add you.`
    : "Your Google account is not on the admin list.",
  oauth_failed: "Google sign-in failed. Try again.",
  access_denied: "Sign-in was cancelled.",
};
const errorText = error ? (errorMessages[error] ?? `Sign-in failed: ${error}`) : null;

const title = "Sign in · ZafTech Admin";
const description = "Internal admin console for ZafTech submissions.";
---
<Layout title={title} description={description}>
  <Fragment slot="head">
    <SeoHead title={title} description={description} noindex={true} canonicalPath="/admin/login" />
  </Fragment>

  <main class="min-h-screen flex items-center justify-center px-6 py-16 bg-onyx-950">
    <div class="w-full max-w-md">
      <a href="/" class="flex items-center gap-3" aria-label="ZafTech home">
        <picture>
          <source srcset="/logo/ZAFTECH_LOGO_Square_bgremoved_dark_theme.png" media="(prefers-color-scheme: light)" />
          <img src="/logo/ZAFTECH_LOGO_Square_bgremoved_light_theme.png" alt="ZafTech Solutions" class="h-12 w-auto" width="48" height="48" draggable="false" />
        </picture>
        <span class="font-mono text-[11px] uppercase tracking-widest text-spruce-400">ZafTech <span class="text-onyx-500">// admin</span></span>
      </a>

      <div class="mt-10 border border-onyx-800 bg-onyx-950 p-7">
        <p class="kicker"><span class="text-onyx-500 mr-1">// 00</span><span>Sign in</span></p>
        <h1 class="mt-3 display-tight text-2xl md:text-3xl font-medium text-ivory-100">
          Admin console
        </h1>
        <p class="mt-3 text-onyx-300 text-[14px] leading-relaxed">
          Sign in with the Google account on the admin list to view contact, career, and audit submissions.
        </p>

        {errorText && (
          <div class="mt-5 border-l-2 border-spruce-500 pl-4 py-2 text-[13px] text-onyx-200 leading-relaxed bg-onyx-900">
            {errorText}
          </div>
        )}

        <button
          type="button"
          class="mt-7 btn-primary w-full"
          data-google-signin
        >
          <svg width="14" height="14" viewBox="0 0 48 48" aria-hidden="true">
            <path fill="#fff" d="M43.6 20.5h-1.9V20H24v8h11.3c-1.7 4.8-6.2 8-11.3 8a12 12 0 1 1 0-24 12 12 0 0 1 8.5 3.5l5.7-5.7A20 20 0 1 0 44 24c0-1.2-.1-2.4-.4-3.5z"/>
          </svg>
          <span data-signin-label>Sign in with Google</span>
        </button>

        <p class="mt-5 font-mono text-[10px] uppercase tracking-widest text-onyx-500 leading-relaxed">
          Restricted access. Activity is logged.
        </p>
      </div>

      <p class="mt-6 text-center font-mono text-[10px] uppercase tracking-widest text-onyx-500">
        <a href="/" class="hover:text-spruce-400 transition-colors">back to zaftech.co</a>
      </p>
    </div>
  </main>

  <script>
    import { createAuthClient } from "better-auth/client";
    const authClient = createAuthClient();

    const button = document.querySelector("[data-google-signin]") as HTMLButtonElement | null;
    const label = document.querySelector("[data-signin-label]") as HTMLElement | null;
    if (button && label) {
      button.addEventListener("click", async () => {
        button.setAttribute("disabled", "true");
        label.textContent = "Redirecting…";
        try {
          await authClient.signIn.social({
            provider: "google",
            callbackURL: "/admin",
            errorCallbackURL: "/admin/login?error=oauth_failed",
          });
        } catch (err) {
          console.error("Sign-in failed:", err);
          button.removeAttribute("disabled");
          label.textContent = "Sign in with Google";
        }
      });
    }
  </script>
</Layout>
