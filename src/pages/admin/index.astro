---
import Layout from "@/layouts/Layout.astro";
import SeoHead from "@/components/SeoHead.astro";
import { guardAdminPage } from "@/lib/admin/auth";
import { db } from "@/lib/db";

export const prerender = false;

const gate = await guardAdminPage(Astro);
if (gate instanceof Response) return gate;
const admin = gate;

const url = new URL(Astro.request.url);
const tabRaw = (url.searchParams.get("tab") ?? "contact").toLowerCase();
const tab = (["contact", "careers", "audit"].includes(tabRaw) ? tabRaw : "contact") as
  | "contact"
  | "careers"
  | "audit";

const showHandledRaw = (url.searchParams.get("show") ?? "open").toLowerCase();
const showHandled = showHandledRaw === "all" ? "all" : showHandledRaw === "handled" ? "handled" : "open";

const PAGE_SIZE = 50;
const pageParam = Number(url.searchParams.get("page") ?? "1");
const page = Number.isFinite(pageParam) && pageParam > 0 ? Math.floor(pageParam) : 1;
const offset = (page - 1) * PAGE_SIZE;

type CommonRow = {
  id: string;
  name: string;
  email: string;
  user_agent: string | null;
  ip_address: string | null;
  created_at: string;
  handled_at: string | null;
};
type ContactRow = CommonRow & { message: string };
type CareersRow = CommonRow & {
  phone: string | null;
  position: string;
  experience: string | null;
  portfolio: string | null;
  message: string | null;
};
type AuditRow = CommonRow & {
  building: string;
  problem: string;
  tech_stack: string | null;
};

type TileCounts = { open: number; total: number };
let counts: Record<"contact" | "careers" | "audit", TileCounts> = {
  contact: { open: 0, total: 0 },
  careers: { open: 0, total: 0 },
  audit: { open: 0, total: 0 },
};
let rows: Array<ContactRow | CareersRow | AuditRow> = [];
let totalForTab = 0;
let dbError: string | null = null;

if (!db) {
  dbError = "DATABASE_URL is not configured on the server.";
} else {
  try {
    // Ensure submission tables exist and have the handled_at column.
    await db`
      CREATE TABLE IF NOT EXISTS contact_submissions (
        id TEXT PRIMARY KEY, name TEXT NOT NULL, email TEXT NOT NULL, message TEXT NOT NULL,
        user_agent TEXT, ip_address TEXT, created_at TEXT NOT NULL
      );
    `;
    await db`
      CREATE TABLE IF NOT EXISTS career_applications (
        id TEXT PRIMARY KEY, name TEXT NOT NULL, email TEXT NOT NULL, phone TEXT,
        position TEXT NOT NULL, experience TEXT, portfolio TEXT, message TEXT,
        user_agent TEXT, ip_address TEXT, created_at TEXT NOT NULL
      );
    `;
    await db`
      CREATE TABLE IF NOT EXISTS audit_submissions (
        id TEXT PRIMARY KEY, name TEXT NOT NULL, email TEXT NOT NULL,
        building TEXT NOT NULL, problem TEXT NOT NULL, tech_stack TEXT,
        user_agent TEXT, ip_address TEXT, created_at TEXT NOT NULL
      );
    `;
    await db`ALTER TABLE contact_submissions   ADD COLUMN IF NOT EXISTS handled_at TIMESTAMPTZ;`;
    await db`ALTER TABLE career_applications  ADD COLUMN IF NOT EXISTS handled_at TIMESTAMPTZ;`;
    await db`ALTER TABLE audit_submissions    ADD COLUMN IF NOT EXISTS handled_at TIMESTAMPTZ;`;

    type CountRow = { open: number; total: number };
    const [c, k, a] = await Promise.all([
      db`SELECT COUNT(*) FILTER (WHERE handled_at IS NULL)::int AS "open", COUNT(*)::int AS "total" FROM contact_submissions;`,
      db`SELECT COUNT(*) FILTER (WHERE handled_at IS NULL)::int AS "open", COUNT(*)::int AS "total" FROM career_applications;`,
      db`SELECT COUNT(*) FILTER (WHERE handled_at IS NULL)::int AS "open", COUNT(*)::int AS "total" FROM audit_submissions;`,
    ]);
    const row = (r: unknown): CountRow => (r as CountRow[])[0] ?? { open: 0, total: 0 };
    counts = {
      contact: row(c),
      careers: row(k),
      audit: row(a),
    };

    // Total + page of rows for the current (tab, filter). Bun's tagged
    // template doesn't interpolate SQL identifiers/clauses, so each branch
    // writes its own statement.
    if (tab === "contact") {
      const totalRows = showHandled === "open"
        ? (await db`SELECT COUNT(*)::int AS n FROM contact_submissions WHERE handled_at IS NULL;`) as Array<{ n: number }>
        : showHandled === "handled"
          ? (await db`SELECT COUNT(*)::int AS n FROM contact_submissions WHERE handled_at IS NOT NULL;`) as Array<{ n: number }>
          : (await db`SELECT COUNT(*)::int AS n FROM contact_submissions;`) as Array<{ n: number }>;
      totalForTab = totalRows[0]?.n ?? 0;
      rows = (showHandled === "open"
        ? await db`
            SELECT id, name, email, message, user_agent, ip_address, created_at, handled_at
            FROM contact_submissions WHERE handled_at IS NULL
            ORDER BY created_at DESC LIMIT ${PAGE_SIZE} OFFSET ${offset};`
        : showHandled === "handled"
          ? await db`
            SELECT id, name, email, message, user_agent, ip_address, created_at, handled_at
            FROM contact_submissions WHERE handled_at IS NOT NULL
            ORDER BY created_at DESC LIMIT ${PAGE_SIZE} OFFSET ${offset};`
          : await db`
            SELECT id, name, email, message, user_agent, ip_address, created_at, handled_at
            FROM contact_submissions ORDER BY created_at DESC LIMIT ${PAGE_SIZE} OFFSET ${offset};`) as ContactRow[];
    } else if (tab === "careers") {
      const totalRows = showHandled === "open"
        ? (await db`SELECT COUNT(*)::int AS n FROM career_applications WHERE handled_at IS NULL;`) as Array<{ n: number }>
        : showHandled === "handled"
          ? (await db`SELECT COUNT(*)::int AS n FROM career_applications WHERE handled_at IS NOT NULL;`) as Array<{ n: number }>
          : (await db`SELECT COUNT(*)::int AS n FROM career_applications;`) as Array<{ n: number }>;
      totalForTab = totalRows[0]?.n ?? 0;
      rows = (showHandled === "open"
        ? await db`
            SELECT id, name, email, phone, position, experience, portfolio, message, user_agent, ip_address, created_at, handled_at
            FROM career_applications WHERE handled_at IS NULL
            ORDER BY created_at DESC LIMIT ${PAGE_SIZE} OFFSET ${offset};`
        : showHandled === "handled"
          ? await db`
            SELECT id, name, email, phone, position, experience, portfolio, message, user_agent, ip_address, created_at, handled_at
            FROM career_applications WHERE handled_at IS NOT NULL
            ORDER BY created_at DESC LIMIT ${PAGE_SIZE} OFFSET ${offset};`
          : await db`
            SELECT id, name, email, phone, position, experience, portfolio, message, user_agent, ip_address, created_at, handled_at
            FROM career_applications ORDER BY created_at DESC LIMIT ${PAGE_SIZE} OFFSET ${offset};`) as CareersRow[];
    } else {
      const totalRows = showHandled === "open"
        ? (await db`SELECT COUNT(*)::int AS n FROM audit_submissions WHERE handled_at IS NULL;`) as Array<{ n: number }>
        : showHandled === "handled"
          ? (await db`SELECT COUNT(*)::int AS n FROM audit_submissions WHERE handled_at IS NOT NULL;`) as Array<{ n: number }>
          : (await db`SELECT COUNT(*)::int AS n FROM audit_submissions;`) as Array<{ n: number }>;
      totalForTab = totalRows[0]?.n ?? 0;
      rows = (showHandled === "open"
        ? await db`
            SELECT id, name, email, building, problem, tech_stack, user_agent, ip_address, created_at, handled_at
            FROM audit_submissions WHERE handled_at IS NULL
            ORDER BY created_at DESC LIMIT ${PAGE_SIZE} OFFSET ${offset};`
        : showHandled === "handled"
          ? await db`
            SELECT id, name, email, building, problem, tech_stack, user_agent, ip_address, created_at, handled_at
            FROM audit_submissions WHERE handled_at IS NOT NULL
            ORDER BY created_at DESC LIMIT ${PAGE_SIZE} OFFSET ${offset};`
          : await db`
            SELECT id, name, email, building, problem, tech_stack, user_agent, ip_address, created_at, handled_at
            FROM audit_submissions ORDER BY created_at DESC LIMIT ${PAGE_SIZE} OFFSET ${offset};`) as AuditRow[];
    }
  } catch (err) {
    dbError = err instanceof Error ? err.message : "Unknown DB error";
    console.error("[admin] dashboard load failed:", err);
  }
}

const tabs = [
  { id: "contact", label: "Contact", open: counts.contact.open, total: counts.contact.total },
  { id: "careers", label: "Careers", open: counts.careers.open, total: counts.careers.total },
  { id: "audit",   label: "Audit",   open: counts.audit.open,   total: counts.audit.total },
] as const;

const fmtDate = (iso: string | null) => {
  if (!iso) return "—";
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso;
  const pad = (n: number) => String(n).padStart(2, "0");
  return `${d.getUTCFullYear()}-${pad(d.getUTCMonth() + 1)}-${pad(d.getUTCDate())} ${pad(d.getUTCHours())}:${pad(d.getUTCMinutes())} UTC`;
};

const truncate = (s: string | null | undefined, n: number) => {
  if (!s) return "";
  return s.length > n ? s.slice(0, n - 1) + "…" : s;
};

const title = "Submissions · ZafTech Admin";
const description = "Internal admin console.";
---
<Layout title={title} description={description}>
  <Fragment slot="head">
    <SeoHead title={title} description={description} noindex={true} canonicalPath="/admin" />
  </Fragment>

  <div class="min-h-screen flex flex-col bg-onyx-950">
    <header class="border-b border-onyx-800 sticky top-0 z-30 bg-onyx-950/95 backdrop-blur-sm">
      <div class="max-w-7xl mx-auto px-6 md:px-12 py-3 flex items-center justify-between gap-4">
        <div class="flex items-center gap-6">
          <a href="/admin" class="flex items-center gap-3" aria-label="ZafTech Admin">
            <picture>
              <source srcset="/logo/ZAFTECH_LOGO_Square_bgremoved_dark_theme.png" media="(prefers-color-scheme: light)" />
              <img src="/logo/ZAFTECH_LOGO_Square_bgremoved_light_theme.png" alt="ZafTech" class="h-9 w-auto" width="36" height="36" draggable="false" />
            </picture>
            <span class="hidden sm:inline font-mono text-[10px] uppercase tracking-widest text-spruce-400">ZafTech <span class="text-onyx-500">// admin</span></span>
          </a>
          <nav class="hidden md:flex items-center gap-5" aria-label="Admin navigation">
            <a href="/admin" class="text-[10px] font-mono uppercase tracking-widest text-spruce-400" aria-current="page">Submissions</a>
            <a href="/admin/admins" class="text-[10px] font-mono uppercase tracking-widest text-onyx-400 hover:text-spruce-400 transition-colors">Admins</a>
            <a href="/admin/mcp" class="text-[10px] font-mono uppercase tracking-widest text-onyx-400 hover:text-spruce-400 transition-colors">MCP</a>
          </nav>
        </div>
        <div class="flex items-center gap-4">
          <span class="hidden sm:inline font-mono text-[10px] uppercase tracking-widest text-onyx-400">{admin.email}</span>
          <button type="button" class="btn-ghost h-9 px-4" data-signout>Sign out</button>
        </div>
      </div>
    </header>

    <main class="grow">
      <section class="px-6 md:px-12 pt-10 pb-4 max-w-7xl mx-auto w-full">
        <p class="kicker"><span class="text-onyx-500 mr-1">// 01</span><span>Overview</span></p>
        <h1 class="mt-3 display-tight text-3xl md:text-4xl font-medium text-ivory-100">Submissions</h1>
        <p class="mt-3 font-mono text-[10px] uppercase tracking-widest text-onyx-500">Counts show open (unhandled) items.</p>

        <div class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-4">
          {tabs.map((t) => (
            <a
              href={`/admin?tab=${t.id}`}
              class:list={[
                "metric-tile relative overflow-hidden transition-colors block",
                tab === t.id ? "border-spruce-400" : "hover:border-onyx-700",
              ]}
              aria-label={`${t.label} — ${t.open} open of ${t.total} total`}
            >
              <span
                aria-hidden="true"
                class="absolute right-3 -top-2 font-mono text-7xl md:text-8xl font-medium leading-none text-onyx-700/40 select-none pointer-events-none"
              >{t.total}</span>
              <div class="value relative z-10">{t.open}</div>
              <div class="label relative z-10">{t.label} <span class="text-onyx-500">/ open</span></div>
            </a>
          ))}
        </div>
      </section>

      <section class="px-6 md:px-12 max-w-7xl mx-auto w-full">
        <div class="mt-6 border-b border-onyx-800 flex items-end gap-1 overflow-x-auto overflow-y-hidden whitespace-nowrap">
          {tabs.map((t) => (
            <a
              href={`/admin?tab=${t.id}${showHandled !== "open" ? `&show=${showHandled}` : ""}`}
              class:list={[
                "px-4 py-3 font-mono text-[11px] uppercase tracking-widest transition-colors -mb-px border-b shrink-0",
                tab === t.id
                  ? "text-spruce-400 border-spruce-400"
                  : "text-onyx-400 border-transparent hover:text-spruce-400",
              ]}
            >
              {t.label}<span class="ml-2 text-onyx-500">{t.open}</span>
            </a>
          ))}
        </div>

        <div class="mt-4 flex flex-wrap gap-2">
          {[
            { id: "open",    label: "Open" },
            { id: "handled", label: "Handled" },
            { id: "all",     label: "All" },
          ].map((f) => (
            <a
              href={`/admin?tab=${tab}${f.id !== "open" ? `&show=${f.id}` : ""}`}
              class:list={[
                "px-3 py-1.5 font-mono text-[10px] uppercase tracking-widest border transition-colors",
                showHandled === f.id
                  ? "border-spruce-400 text-spruce-400"
                  : "border-onyx-800 text-onyx-400 hover:border-onyx-700 hover:text-spruce-400",
              ]}
            >{f.label}</a>
          ))}
        </div>
      </section>

      <section class="px-6 md:px-12 max-w-7xl mx-auto w-full pb-16">
        <div class="mt-6 border border-onyx-800 bg-onyx-950">
          {dbError ? (
            <div class="p-6 text-[14px] text-onyx-200">
              <p class="font-mono text-[10px] uppercase tracking-widest text-spruce-400 mb-2">// db error</p>
              {dbError}
            </div>
          ) : rows.length === 0 ? (
            <div class="p-10 text-center">
              <p class="font-mono text-[10px] uppercase tracking-widest text-onyx-500">// no submissions matching this filter</p>
            </div>
          ) : (
            <div class="overflow-x-auto">
              <table class="w-full text-left" data-admin-table>
                <thead>
                  <tr class="border-b border-onyx-700">
                    <th class="font-mono text-[10px] uppercase tracking-widest text-spruce-400 px-4 py-3 whitespace-nowrap">Received</th>
                    <th class="font-mono text-[10px] uppercase tracking-widest text-spruce-400 px-4 py-3">Name</th>
                    <th class="font-mono text-[10px] uppercase tracking-widest text-spruce-400 px-4 py-3">Email</th>
                    {tab === "contact" && (
                      <th class="font-mono text-[10px] uppercase tracking-widest text-spruce-400 px-4 py-3">Message</th>
                    )}
                    {tab === "careers" && (
                      <>
                        <th class="font-mono text-[10px] uppercase tracking-widest text-spruce-400 px-4 py-3">Position</th>
                        <th class="font-mono text-[10px] uppercase tracking-widest text-spruce-400 px-4 py-3">Message</th>
                      </>
                    )}
                    {tab === "audit" && (
                      <>
                        <th class="font-mono text-[10px] uppercase tracking-widest text-spruce-400 px-4 py-3">Building</th>
                        <th class="font-mono text-[10px] uppercase tracking-widest text-spruce-400 px-4 py-3">Problem</th>
                      </>
                    )}
                    <th class="font-mono text-[10px] uppercase tracking-widest text-spruce-400 px-4 py-3 whitespace-nowrap">Status</th>
                  </tr>
                </thead>
                <tbody>
                  {rows.map((r) => {
                    const detail = { type: tab, ...r };
                    const handled = !!r.handled_at;
                    return (
                      <tr
                        class:list={[
                          "border-b border-onyx-800 cursor-pointer transition-colors",
                          handled ? "opacity-60 hover:bg-onyx-900/60" : "hover:bg-onyx-900",
                        ]}
                        data-row
                        data-detail={JSON.stringify(detail)}
                      >
                        <td class="px-4 py-3 font-mono text-[11px] text-onyx-400 whitespace-nowrap">{fmtDate(r.created_at)}</td>
                        <td class="px-4 py-3 text-[14px] text-ivory-100">{r.name}</td>
                        <td class="px-4 py-3 text-[14px] text-spruce-400">{r.email}</td>
                        {tab === "contact" && (
                          <td class="px-4 py-3 text-[13px] text-onyx-300">{truncate((r as ContactRow).message, 80)}</td>
                        )}
                        {tab === "careers" && (
                          <>
                            <td class="px-4 py-3 text-[13px] text-onyx-200">{(r as CareersRow).position}</td>
                            <td class="px-4 py-3 text-[13px] text-onyx-300">{truncate((r as CareersRow).message ?? "", 80)}</td>
                          </>
                        )}
                        {tab === "audit" && (
                          <>
                            <td class="px-4 py-3 text-[13px] text-onyx-200">{truncate((r as AuditRow).building, 60)}</td>
                            <td class="px-4 py-3 text-[13px] text-onyx-300">{truncate((r as AuditRow).problem, 80)}</td>
                          </>
                        )}
                        <td class="px-4 py-3 whitespace-nowrap">
                          {handled ? (
                            <span class="font-mono text-[10px] uppercase tracking-widest text-onyx-500">handled</span>
                          ) : (
                            <span class="font-mono text-[10px] uppercase tracking-widest text-spruce-400">open</span>
                          )}
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          )}
        </div>

        {rows.length > 0 && (() => {
          const totalPages = Math.max(1, Math.ceil(totalForTab / PAGE_SIZE));
          const start = offset + 1;
          const end = offset + rows.length;
          const baseQuery = `tab=${tab}${showHandled !== "open" ? `&show=${showHandled}` : ""}`;
          const prevHref = page > 1 ? `/admin?${baseQuery}&page=${page - 1}` : null;
          const nextHref = page < totalPages ? `/admin?${baseQuery}&page=${page + 1}` : null;
          return (
            <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
              <p class="font-mono text-[10px] uppercase tracking-widest text-onyx-500">
                {start}–{end} of {totalForTab} · page {page} of {totalPages} · click a row to view detail
              </p>
              <div class="flex items-center gap-2">
                {prevHref ? (
                  <a href={prevHref} class="btn-ghost h-8 px-3 text-[10px]">← Prev</a>
                ) : (
                  <span class="btn-ghost h-8 px-3 text-[10px] opacity-40 pointer-events-none">← Prev</span>
                )}
                {nextHref ? (
                  <a href={nextHref} class="btn-ghost h-8 px-3 text-[10px]">Next →</a>
                ) : (
                  <span class="btn-ghost h-8 px-3 text-[10px] opacity-40 pointer-events-none">Next →</span>
                )}
              </div>
            </div>
          );
        })()}
      </section>
    </main>

    <!-- Detail drawer -->
    <div id="admin-drawer" class="fixed inset-0 z-50 pointer-events-none" aria-hidden="true">
      <div class="absolute inset-0 bg-onyx-950/70 opacity-0 transition-opacity duration-200 pointer-events-none" data-drawer-backdrop></div>
      <aside
        class="absolute top-0 right-0 h-full w-full sm:w-[520px] max-w-[100vw] bg-onyx-950 border-l border-onyx-800 transform translate-x-full transition-transform duration-200 ease-out overflow-y-auto"
        data-drawer-panel
        aria-label="Submission detail"
      >
        <div class="p-6 md:p-7">
          <div class="flex items-center justify-between gap-3">
            <p class="kicker"><span class="text-onyx-500 mr-1">// rec</span><span data-drawer-type>—</span></p>
            <button type="button" data-drawer-close class="h-9 w-9 flex items-center justify-center text-onyx-400 hover:text-spruce-400 transition-colors" aria-label="Close detail">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </div>
          <p class="mt-2 font-mono text-[10px] uppercase tracking-widest text-onyx-500" data-drawer-received>—</p>
          <p class="mt-1 font-mono text-[10px] uppercase tracking-widest" data-drawer-handled></p>
          <h2 class="mt-4 display-tight text-2xl font-medium text-ivory-100" data-drawer-name>—</h2>
          <a class="mt-1 inline-block text-[14px] text-spruce-400 hover:text-spruce-300 transition-colors" data-drawer-email href="#">—</a>

          <div class="mt-6 space-y-5" data-drawer-fields></div>

          <div class="mt-8 pt-5 border-t border-onyx-800 space-y-2 font-mono text-[11px]">
            <div class="flex justify-between gap-4">
              <span class="text-onyx-400">IP</span>
              <span class="text-onyx-300 truncate" data-drawer-ip>—</span>
            </div>
            <div class="flex justify-between gap-4">
              <span class="text-onyx-400">User agent</span>
              <span class="text-onyx-300 text-right break-words max-w-[70%]" data-drawer-ua>—</span>
            </div>
          </div>

          <!-- Actions -->
          <div class="mt-8 flex flex-wrap gap-3" data-drawer-actions>
            <button type="button" class="btn-primary" data-action-handle>Mark handled</button>
            <button type="button" class="btn-ghost" data-action-reachout hidden>Reach out</button>
          </div>

          <!-- Compose -->
          <form class="mt-6 border border-onyx-800 bg-onyx-900 p-5" data-reachout-form hidden novalidate>
            <p class="font-mono text-[10px] uppercase tracking-widest text-spruce-400">Compose reply</p>
            <p class="mt-1 font-mono text-[10px] uppercase tracking-widest text-onyx-500">From: <span data-reachout-from>SMTP_FROM</span></p>
            <label class="block mt-4">
              <span class="font-mono text-[10px] uppercase tracking-widest text-onyx-400">Subject</span>
              <input type="text" name="subject" required class="mt-2 w-full bg-onyx-950 border border-onyx-800 text-ivory-100 placeholder-onyx-500/60 px-4 py-3" />
            </label>
            <label class="block mt-4">
              <span class="font-mono text-[10px] uppercase tracking-widest text-onyx-400">Message</span>
              <textarea name="body" required rows="8" class="mt-2 w-full bg-onyx-950 border border-onyx-800 text-ivory-100 placeholder-onyx-500/60 px-4 py-3 resize-none"></textarea>
            </label>
            <div class="mt-4 flex items-center justify-between gap-3">
              <p class="font-mono text-[10px] uppercase tracking-widest text-onyx-500" data-reachout-status>Sending also marks this submission handled.</p>
              <div class="flex gap-2">
                <button type="button" class="btn-ghost h-9 px-4" data-reachout-cancel>Cancel</button>
                <button type="submit" class="btn-primary h-9 px-4">Send</button>
              </div>
            </div>
          </form>
        </div>
      </aside>
    </div>

    <footer class="border-t border-onyx-800 mt-auto">
      <div class="max-w-7xl mx-auto px-6 md:px-12 py-5 font-mono text-[10px] uppercase tracking-widest text-onyx-500 flex flex-col sm:flex-row gap-2 sm:items-center sm:justify-between">
        <span>ZafTech admin · internal</span>
        <span><a href="/" class="hover:text-spruce-400 transition-colors">back to zaftech.co</a></span>
      </div>
    </footer>
  </div>

  <script>
    import { createAuthClient } from "better-auth/client";
    const authClient = createAuthClient();

    document.querySelector("[data-signout]")?.addEventListener("click", async () => {
      await authClient.signOut();
      window.location.href = "/admin/login";
    });
  </script>

  <script is:inline>
    (function () {
      const drawer = document.getElementById("admin-drawer");
      if (!drawer) return;
      const panel = drawer.querySelector("[data-drawer-panel]");
      const backdrop = drawer.querySelector("[data-drawer-backdrop]");
      const closeBtn = drawer.querySelector("[data-drawer-close]");
      const rows = Array.from(document.querySelectorAll("[data-row]"));

      const fieldsEl = drawer.querySelector("[data-drawer-fields]");
      const typeEl = drawer.querySelector("[data-drawer-type]");
      const receivedEl = drawer.querySelector("[data-drawer-received]");
      const handledEl = drawer.querySelector("[data-drawer-handled]");
      const nameEl = drawer.querySelector("[data-drawer-name]");
      const emailEl = drawer.querySelector("[data-drawer-email]");
      const ipEl = drawer.querySelector("[data-drawer-ip]");
      const uaEl = drawer.querySelector("[data-drawer-ua]");
      const actionHandle = drawer.querySelector("[data-action-handle]");
      const actionReach = drawer.querySelector("[data-action-reachout]");
      const reachForm = drawer.querySelector("[data-reachout-form]");
      const reachStatus = drawer.querySelector("[data-reachout-status]");
      const reachCancel = drawer.querySelector("[data-reachout-cancel]");

      const FIELDS = {
        contact: [{ key: "message", label: "Message" }],
        careers: [
          { key: "position", label: "Position" },
          { key: "phone", label: "Phone" },
          { key: "portfolio", label: "Portfolio" },
          { key: "experience", label: "Experience" },
          { key: "message", label: "Message" },
        ],
        audit: [
          { key: "building", label: "What they're building" },
          { key: "problem", label: "Main problem" },
          { key: "tech_stack", label: "Tech stack" },
        ],
      };

      const fmtDate = (iso) => {
        if (!iso) return "—";
        const d = new Date(iso);
        if (Number.isNaN(d.getTime())) return iso;
        const pad = (n) => String(n).padStart(2, "0");
        return `${d.getUTCFullYear()}-${pad(d.getUTCMonth() + 1)}-${pad(d.getUTCDate())} ${pad(d.getUTCHours())}:${pad(d.getUTCMinutes())} UTC`;
      };

      let current = null;

      const renderHandled = () => {
        if (!current) return;
        if (current.handled_at) {
          handledEl.textContent = "Handled  //  " + fmtDate(current.handled_at);
          handledEl.classList.add("text-spruce-400");
          handledEl.classList.remove("text-onyx-500");
          actionHandle.textContent = "Mark unhandled";
        } else {
          handledEl.textContent = "Open  //  not yet handled";
          handledEl.classList.add("text-onyx-500");
          handledEl.classList.remove("text-spruce-400");
          actionHandle.textContent = "Mark handled";
        }
      };

      const open = (data) => {
        current = data;
        typeEl.textContent = data.type;
        receivedEl.textContent = "Received  //  " + fmtDate(data.created_at);
        nameEl.textContent = data.name || "—";
        emailEl.textContent = data.email || "—";
        emailEl.href = data.email ? `mailto:${data.email}` : "#";
        ipEl.textContent = data.ip_address || "—";
        uaEl.textContent = data.user_agent || "—";

        const fields = FIELDS[data.type] || [];
        fieldsEl.innerHTML = "";
        for (const f of fields) {
          const val = data[f.key];
          if (val === undefined || val === null || val === "") continue;
          const wrap = document.createElement("div");
          const label = document.createElement("p");
          label.className = "font-mono text-[10px] uppercase tracking-widest text-onyx-400";
          label.textContent = f.label;
          const body = document.createElement("p");
          body.className = "mt-2 text-[14px] text-onyx-200 leading-relaxed whitespace-pre-wrap";
          body.textContent = String(val);
          wrap.appendChild(label);
          wrap.appendChild(body);
          fieldsEl.appendChild(wrap);
        }

        // Reach out only for contact + careers.
        if (data.type === "audit") {
          actionReach.setAttribute("hidden", "true");
        } else {
          actionReach.removeAttribute("hidden");
        }
        reachForm.setAttribute("hidden", "true");
        const subjEl = reachForm.querySelector("[name=subject]");
        const bodyEl = reachForm.querySelector("[name=body]");
        subjEl.value = data.type === "careers"
          ? `Re: your application — ${data.position || "ZafTech"}`
          : "Re: your message to ZafTech";
        bodyEl.value = `Hi ${data.name?.split(" ")[0] || ""},\n\n\n\nBest,\nZafTech team`;
        reachStatus.textContent = "Sending also marks this submission handled.";
        reachStatus.classList.remove("text-spruce-400", "text-red-400");

        renderHandled();

        drawer.setAttribute("aria-hidden", "false");
        drawer.classList.remove("pointer-events-none");
        backdrop.classList.remove("pointer-events-none", "opacity-0");
        panel.classList.remove("translate-x-full");
        document.body.style.overflow = "hidden";
      };

      const close = () => {
        drawer.setAttribute("aria-hidden", "true");
        drawer.classList.add("pointer-events-none");
        backdrop.classList.add("pointer-events-none", "opacity-0");
        panel.classList.add("translate-x-full");
        document.body.style.overflow = "";
      };

      rows.forEach((row) => {
        row.addEventListener("click", () => {
          try { open(JSON.parse(row.getAttribute("data-detail") || "{}")); } catch (e) { /* ignore */ }
        });
      });
      closeBtn?.addEventListener("click", close);
      backdrop?.addEventListener("click", close);
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && drawer.getAttribute("aria-hidden") === "false") {
          if (!reachForm.hasAttribute("hidden")) reachForm.setAttribute("hidden", "true");
          else close();
        }
      });

      actionHandle?.addEventListener("click", async () => {
        if (!current) return;
        const next = !current.handled_at;
        actionHandle.setAttribute("disabled", "true");
        try {
          const res = await fetch("/api/admin/handled", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ type: current.type, id: current.id, handled: next }),
          });
          const body = await res.json();
          if (!res.ok || !body.ok) throw new Error(body.error || "Failed");
          current.handled_at = body.handled_at;
          renderHandled();
        } catch (err) {
          alert("Failed: " + (err.message || err));
        } finally {
          actionHandle.removeAttribute("disabled");
        }
      });

      actionReach?.addEventListener("click", () => {
        reachForm.removeAttribute("hidden");
        reachForm.querySelector("[name=subject]").focus();
      });
      reachCancel?.addEventListener("click", () => reachForm.setAttribute("hidden", "true"));

      reachForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!current) return;
        const data = Object.fromEntries(new FormData(e.target));
        reachStatus.textContent = "Sending…";
        reachStatus.classList.remove("text-red-400", "text-spruce-400");
        try {
          const res = await fetch("/api/admin/reachout", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ type: current.type, id: current.id, subject: data.subject, body: data.body }),
          });
          const body = await res.json();
          if (!res.ok || !body.ok) throw new Error(body.error || "Send failed");
          reachStatus.textContent = "Sent. Submission marked handled.";
          reachStatus.classList.add("text-spruce-400");
          current.handled_at = body.handled_at ?? new Date().toISOString();
          renderHandled();
          window.setTimeout(() => reachForm.setAttribute("hidden", "true"), 1200);
        } catch (err) {
          reachStatus.textContent = "Failed: " + (err.message || err);
          reachStatus.classList.add("text-red-400");
        }
      });
    })();
  </script>
</Layout>
