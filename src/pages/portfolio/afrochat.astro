---
import Layout from "@/layouts/Layout.astro";
import SeoHead from "@/components/SeoHead.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import RevealObserver from "@/components/RevealObserver.astro";
import Kicker from "@/components/ui/Kicker.astro";
import Button from "@/components/ui/Button.astro";
import MetricTile from "@/components/ui/MetricTile.astro";
import WireframeAvatar from "@/components/svg/WireframeAvatar.astro";
import ArchitectureDiagram from "@/components/svg/ArchitectureDiagram.astro";

export const prerender = true;

const title = "AfroChat: scaled to 2,000 users on 27% of the budget · ZafTech";
const description = "How we rebuilt a generative-AI platform's infrastructure in 14 weeks, cut cost 73%, and kept the team shipping features.";
---
<Layout title={title} description={description}>
  <Fragment slot="head">
    <SeoHead
      title={title}
      description={description}
      canonicalPath="/portfolio/afrochat"
      type="article"
      jsonLd={{
        "@context": "https://schema.org",
        "@type": "Article",
        headline: "AfroChat: scaled to 2,000 users on 27% of the budget",
        description,
        author: { "@type": "Organization", name: "ZafTech Solutions" },
        datePublished: "2025-11-01",
        dateModified: "2026-04-24",
      }}
    />
  </Fragment>

  <div class="min-h-screen flex flex-col">
    <SiteHeader />

    <main class="grow">
      <!-- Hero -->
      <section class="px-6 md:px-12 pt-28 pb-14 border-b border-onyx-800">
        <div class="max-w-6xl mx-auto reveal-up">
          <nav class="font-mono text-[10px] uppercase tracking-widest text-onyx-500 flex gap-2" aria-label="Breadcrumb">
            <a href="/" class="hover:text-spruce-400 transition-colors">Home</a>
            <span class="text-onyx-700">/</span>
            <a href="/#portfolio" class="hover:text-spruce-400 transition-colors">Portfolio</a>
            <span class="text-onyx-700">/</span>
            <span class="text-spruce-400">AfroChat</span>
          </nav>
          <h1 class="mt-6 display-tight text-4xl md:text-6xl lg:text-7xl font-medium text-ivory-100 max-w-4xl">
            Scaling AfroChat to 2,000 users on <span class="text-spruce-400">27%</span> of the budget.
          </h1>
          <p class="mt-6 text-onyx-300 max-w-3xl text-base md:text-lg leading-relaxed">
            How we rebuilt a generative-AI platform's infrastructure in 14 weeks, took its cost curve from alarming to flat, and kept the team shipping features the whole time.
          </p>

          <div class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-px bg-onyx-800 border border-onyx-800">
            <div class="bg-onyx-950"><MetricTile value="2,341" label="Daily users" trend="up" /></div>
            <div class="bg-onyx-950"><MetricTile value="73%" label="Cost reduction" trend="down" /></div>
            <div class="bg-onyx-950"><MetricTile value="14 wk" label="Time to ship" trend="flat" /></div>
            <div class="bg-onyx-950"><MetricTile value="99.95%" label="Uptime" trend="up" /></div>
          </div>
        </div>
      </section>

      <!-- Architecture diagram -->
      <section class="border-b border-onyx-800 bg-onyx-900/30">
        <div class="px-6 md:px-12 py-16 md:py-20">
          <div class="max-w-6xl mx-auto reveal-up">
            <Kicker label="// afrochat-architecture.svg" tone="muted" />
            <div class="mt-6"><ArchitectureDiagram /></div>
          </div>
        </div>
      </section>

      <!-- At a glance -->
      <section class="border-b border-onyx-800">
        <div class="px-6 md:px-12 py-14">
          <dl class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-10 font-mono text-[11px] uppercase tracking-widest">
            <div>
              <dt class="text-onyx-500">Client</dt>
              <dd class="mt-2 text-ivory-100 normal-case tracking-normal text-sm">AfroChat</dd>
            </div>
            <div>
              <dt class="text-onyx-500">Stack</dt>
              <dd class="mt-2 text-ivory-100 normal-case tracking-normal text-sm">React, Go, Python, Postgres, Redis, AWS</dd>
            </div>
            <div>
              <dt class="text-onyx-500">Team</dt>
              <dd class="mt-2 text-ivory-100 normal-case tracking-normal text-sm">3 engineers, 1 designer</dd>
            </div>
            <div>
              <dt class="text-onyx-500">Duration</dt>
              <dd class="mt-2 text-ivory-100 normal-case tracking-normal text-sm">14 weeks</dd>
            </div>
          </dl>
        </div>
      </section>

      <!-- Problem -->
      <section class="border-b border-onyx-800">
        <div class="px-6 md:px-12 py-20 md:py-24">
          <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12">
            <div class="lg:col-span-4 reveal-up">
              <Kicker num="01" label="The problem" />
            </div>
            <div class="lg:col-span-8 reveal-up">
              <h2 class="display-tight text-3xl md:text-4xl font-medium text-ivory-100">
                A compelling product on a cost structure that would kill it.
              </h2>
              <div class="mt-6 space-y-5 text-onyx-300 text-[15px] md:text-base leading-relaxed max-w-3xl">
                <p>
                  AfroChat had real traction: a growing user base, genuine product-market fit signals, and an engineering team that shipped daily. The problem was the bill. GPU inference, vector retrieval, and synthesis ran on an architecture optimised for the demo, not for thousands of concurrent sessions.
                </p>
                <p>
                  Every doubling of users meant more than doubling of spend. The runway math stopped working.
                </p>
              </div>
              <blockquote class="mt-10 border-l-2 border-spruce-500 pl-6 text-xl md:text-2xl text-ivory-100 leading-snug max-w-3xl">
                "We were one viral tweet away from bankruptcy."
                <footer class="mt-3 font-mono text-[10px] uppercase tracking-widest text-onyx-400">[PLACEHOLDER: founder quote to confirm]</footer>
              </blockquote>
            </div>
          </div>
        </div>
      </section>

      <!-- Approach -->
      <section class="border-b border-onyx-800 bg-onyx-900/30">
        <div class="px-6 md:px-12 py-20 md:py-24">
          <div class="max-w-6xl mx-auto">
            <Kicker num="02" label="Approach" />
            <h2 class="mt-4 display-tight text-3xl md:text-4xl font-medium text-ivory-100 max-w-3xl">
              Three decisions, made in week one.
            </h2>

            <ol class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-px bg-onyx-800 border border-onyx-800">
              <li class="p-7 bg-onyx-950 reveal-up">
                <span class="font-mono text-[10px] text-spruce-400 tracking-widest">/ 01</span>
                <h3 class="mt-4 text-lg font-medium text-ivory-100">Cache aggressively, regenerate sparingly.</h3>
                <p class="mt-3 text-sm text-onyx-300 leading-relaxed">
                  Over 40% of prompts repeat within a week. We built a semantic cache in pgvector; repeat queries hit it before a single token is generated.
                </p>
              </li>
              <li class="p-7 bg-onyx-950 reveal-up" style="--reveal-delay: 80ms;">
                <span class="font-mono text-[10px] text-spruce-400 tracking-widest">/ 02</span>
                <h3 class="mt-4 text-lg font-medium text-ivory-100">Right-size GPUs to the actual peak.</h3>
                <p class="mt-3 text-sm text-onyx-300 leading-relaxed">
                  The old stack ran on always-on A100s. We moved to spot-backed inference workers that scale on a 90-second cold-start budget, with fallback to a smaller warm pool.
                </p>
              </li>
              <li class="p-7 bg-onyx-950 reveal-up" style="--reveal-delay: 160ms;">
                <span class="font-mono text-[10px] text-spruce-400 tracking-widest">/ 03</span>
                <h3 class="mt-4 text-lg font-medium text-ivory-100">Replace the orchestrator with Go.</h3>
                <p class="mt-3 text-sm text-onyx-300 leading-relaxed">
                  The Node/Express API was the bottleneck under streaming. A Go rewrite halved latency and let two replicas carry the load four originally needed.
                </p>
              </li>
            </ol>
          </div>
        </div>
      </section>

      <!-- Outcome -->
      <section class="border-b border-onyx-800">
        <div class="px-6 md:px-12 py-20 md:py-24">
          <div class="max-w-6xl mx-auto">
            <Kicker num="03" label="Outcome" />
            <h2 class="mt-4 display-tight text-3xl md:text-4xl font-medium text-ivory-100">
              14 weeks later.
            </h2>

            <div class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-px bg-onyx-800 border border-onyx-800">
              <div class="bg-onyx-950"><MetricTile value="2,341" label="Daily users" trend="up" /></div>
              <div class="bg-onyx-950"><MetricTile value="73%" label="Cost reduction" trend="down" /></div>
              <div class="bg-onyx-950"><MetricTile value="0.5s" label="Avg response" trend="down" /></div>
              <div class="bg-onyx-950"><MetricTile value="99.95%" label="Uptime" trend="flat" /></div>
            </div>

            <div class="mt-16 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
              <figure class="lg:col-span-8 reveal-up">
                <svg width="48" height="36" viewBox="0 0 32 24" fill="none" aria-hidden="true" class="text-spruce-400">
                  <path d="M0 24V12C0 5 5 0 12 0V6C9 6 7 8 7 12H12V24H0ZM20 24V12C20 5 25 0 32 0V6C29 6 27 8 27 12H32V24H20Z" fill="currentColor"/>
                </svg>
                <blockquote class="mt-6 text-2xl md:text-3xl text-ivory-100 leading-snug">
                  ZafTech didn't just give us a cost reduction. They gave us predictable costs that let our company's runway triple overnight.
                </blockquote>
                <figcaption class="mt-8 flex items-center gap-4">
                  <WireframeAvatar seed={1} size={44} />
                  <div>
                    <div class="text-sm text-ivory-100 font-medium">[PLACEHOLDER: Founder name]</div>
                    <div class="font-mono text-[10px] uppercase tracking-widest text-onyx-500 mt-0.5">Founder, AfroChat</div>
                  </div>
                </figcaption>
              </figure>

              <aside class="lg:col-span-4 reveal-up" style="--reveal-delay: 120ms;">
                <div class="border border-onyx-800 p-6">
                  <p class="kicker kicker-muted">// Tech used</p>
                  <ul class="mt-5 flex flex-wrap gap-1.5">
                    {["React", "Go", "Python", "Postgres", "pgvector", "Redis", "AWS", "Terraform", "GitHub Actions", "Grafana"].map((t) => (
                      <li class="font-mono text-[10px] text-onyx-300 border border-onyx-800 px-2 py-0.5">{t}</li>
                    ))}
                  </ul>
                </div>
              </aside>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="border-b border-onyx-800">
        <div class="px-6 md:px-12 py-24 md:py-32">
          <div class="max-w-4xl mx-auto text-center reveal-up">
            <h2 class="display-tight text-3xl md:text-5xl font-medium text-ivory-100">
              Building something similar?
            </h2>
            <p class="mt-5 text-onyx-300 max-w-xl mx-auto text-base md:text-lg">
              15 minutes. We'll tell you if we can help, and if not, who can.
            </p>
            <div class="mt-10 flex justify-center">
              <Button href="mailto:contact@zaftech.co?subject=Similar%20project" variant="primary">Book a 15-min call</Button>
            </div>
          </div>
        </div>
      </section>
    </main>

    <SiteFooter />
  </div>
  <RevealObserver />
</Layout>
