---
import { Image } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import SeoHead from "@/components/SeoHead.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import RevealObserver from "@/components/RevealObserver.astro";
import Kicker from "@/components/ui/Kicker.astro";
import Button from "@/components/ui/Button.astro";
import { gallery } from "@/data/content";

export const prerender = true;

// Extra editorial copy per project — slug matches the gallery title for lookup.
const meta: Record<string, { year: string; role: string; outcome: string; stack: string[] }> = {
  "Girum Gizaw": {
    year: "2024",
    role: "Design + frontend",
    outcome: "A portfolio that punches above its weight for a senior engineer's job search.",
    stack: ["Astro", "Tailwind", "TypeScript"],
  },
  "Akoya Properties": {
    year: "2024",
    role: "Full-stack build",
    outcome: "Real-estate listings, lead capture, and CMS-backed content for the Akoya brand.",
    stack: ["Next.js", "Node", "Postgres", "AWS"],
  },
  "Bathra": {
    year: "2024",
    role: "Founding engineering",
    outcome: "A matchmaking platform connecting startups to early-stage capital across East Africa.",
    stack: ["Next.js", "Node", "Postgres", "Stripe"],
  },
  "Mizan": {
    year: "2024",
    role: "Product + engineering",
    outcome: "Daily-active nutrition and training platform the founder still uses every day.",
    stack: ["Next.js", "Python", "Postgres", "OpenAI"],
  },
  "Bitbricks": {
    year: "2023",
    role: "Backend + data",
    outcome: "An e-learning stack with lesson analytics and graded exercises.",
    stack: ["Django", "Postgres", "Redis", "Kubernetes"],
  },
};

const title = "Portfolio · ZafTech";
const description = "Shipped, running, still ours to support. A sample of projects our team has taken from idea to production.";
---
<Layout title={title} description={description}>
  <Fragment slot="head">
    <SeoHead title={title} description={description} canonicalPath="/portfolio" />
  </Fragment>

  <div class="min-h-screen flex flex-col">
    <SiteHeader />

    <main class="grow">
      <!-- Hero -->
      <section class="px-6 md:px-12 pt-28 pb-16 border-b border-onyx-800">
        <div class="max-w-6xl mx-auto reveal-up">
          <Kicker num="01" label={`Portfolio · ${gallery.length} projects`} />
          <h1 class="mt-6 display-tight text-4xl md:text-6xl lg:text-7xl font-medium text-ivory-100 max-w-3xl">
            Shipped, running, still ours to support.
          </h1>
          <p class="mt-6 text-onyx-300 max-w-2xl text-base md:text-lg leading-relaxed">
            A sample of projects we've taken from idea to production. Each one links to the live site; most we still maintain.
          </p>
        </div>
      </section>

      <!-- Project rows -->
      <section class="border-b border-onyx-800">
        <ul class="divide-y divide-onyx-800">
          {gallery.map((g, i) => {
            const m = meta[g.title];
            return (
              <li class="reveal-up" style={`--reveal-delay: ${Math.min(i * 60, 240)}ms;`}>
                <article class="px-6 md:px-12 py-16 md:py-20">
                  <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">
                    <!-- Text column -->
                    <div class="lg:col-span-5 lg:order-1 order-2">
                      <div class="flex items-center justify-between gap-4 mb-5">
                        <span class="font-mono text-[10px] tracking-widest text-spruce-400">
                          PROJECT / {String(i + 1).padStart(2, "0")}
                        </span>
                        {m && (
                          <span class="font-mono text-[10px] tracking-widest text-onyx-400 border border-onyx-700 px-2 py-0.5">
                            {m.year}
                          </span>
                        )}
                      </div>

                      <h2 class="display-tight text-3xl md:text-5xl font-medium text-ivory-100">{g.title}</h2>
                      <p class="mt-3 text-base md:text-lg text-onyx-200">{g.tag}</p>
                      {m && (
                        <>
                          <p class="mt-5 text-sm md:text-[15px] text-onyx-300 leading-relaxed max-w-xl">
                            {m.outcome}
                          </p>
                          <dl class="mt-8 grid grid-cols-[96px_1fr] items-baseline gap-y-3 text-sm">
                            <dt class="font-mono text-[10px] uppercase tracking-widest text-onyx-500">Role</dt>
                            <dd class="text-ivory-100">{m.role}</dd>
                            <dt class="font-mono text-[10px] uppercase tracking-widest text-onyx-500">Stack</dt>
                            <dd class="flex flex-wrap gap-1.5">
                              {m.stack.map((s) => (
                                <span class="font-mono text-[10px] text-onyx-300 border border-onyx-800 px-2 py-0.5">{s}</span>
                              ))}
                            </dd>
                          </dl>
                        </>
                      )}

                      <div class="mt-8">
                        <Button href={g.link} variant="primary" external>Visit {g.title.toLowerCase()}</Button>
                      </div>
                    </div>

                    <!-- Image column -->
                    <a
                      href={g.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="lg:col-span-7 lg:order-2 order-1 block card-accent-bar border border-onyx-800 overflow-hidden"
                    >
                      <div class="aspect-[16/10] relative bg-onyx-900">
                        <Image
                          src={g.image}
                          alt={`${g.title}: ${g.tag}`}
                          widths={[640, 960, 1280, 1600]}
                          sizes="(min-width: 1024px) 58vw, 100vw"
                          class="absolute inset-0 w-full h-full object-cover opacity-75 hover:opacity-100 transition-opacity duration-500"
                          draggable={false}
                        />
                      </div>
                    </a>
                  </div>
                </article>
              </li>
            );
          })}
        </ul>
      </section>

      <!-- Final CTA -->
      <section class="border-b border-onyx-800">
        <div class="px-6 md:px-12 py-24 md:py-32">
          <div class="max-w-4xl mx-auto text-center reveal-up">
            <h2 class="display-tight text-3xl md:text-5xl font-medium text-ivory-100">
              Want one of these for your team?
            </h2>
            <p class="mt-5 text-onyx-300 max-w-xl mx-auto text-base md:text-lg">
              15 minutes. We'll scope the problem and tell you honestly if we can help.
            </p>
            <div class="mt-10 flex justify-center">
              <Button href="mailto:contact@zaftech.co?subject=Project%20inquiry" variant="primary">
                Book a 15-min call
              </Button>
            </div>
          </div>
        </div>
      </section>
    </main>

    <SiteFooter />
  </div>
  <RevealObserver />
</Layout>
