---
import Layout from "@/layouts/Layout.astro";
import { services } from "@/data/content";
import type { Service } from "@/data/content";

export const prerender = true;
---

<Layout title="Services | Zaftech Solutions" description="Full-stack engineering, ML/AI, cloud infrastructure, database architecture, WordPress, and more. Explore our comprehensive service offerings.">
  <div class="min-h-screen flex flex-col">
    <!-- Navigation -->
    <header class="fixed top-0 left-0 w-full z-50 border-b border-onyx-700 bg-onyx-950/95 backdrop-blur-sm">
      <div class="px-6 md:px-12 py-4 flex items-center justify-between">
        <div class="flex items-center gap-6">
          <a href="/" class="flex items-center gap-2">
            <div class="w-2 h-2 bg-spruce-400"></div>
            <span class="text-ivory-100 text-sm font-bold tracking-wider">Zaftech Solutions</span>
          </a>
          <div class="hidden md:block h-4 w-px bg-onyx-700"></div>
          <nav class="hidden md:flex gap-6">
            <a class="text-[10px] font-mono text-onyx-400 hover:text-spruce-400 transition-colors uppercase tracking-widest" href="/#services">Capabilities</a>
            <a class="text-[10px] font-mono text-spruce-400 uppercase tracking-widest" href="/services" aria-current="page">Services</a>
            <a class="text-[10px] font-mono text-onyx-400 hover:text-spruce-400 transition-colors uppercase tracking-widest" href="/#products">Products</a>
            <a class="text-[10px] font-mono text-onyx-400 hover:text-spruce-400 transition-colors uppercase tracking-widest" href="/#team">Team</a>
            <a class="text-[10px] font-mono text-onyx-400 hover:text-spruce-400 transition-colors uppercase tracking-widest" href="/#contact">Contact</a>
          </nav>
        </div>
        <div class="flex items-center gap-4">
          <a href="/#contact" class="hidden sm:flex h-9 items-center justify-center px-5 bg-spruce-400 text-onyx-950 text-[10px] font-bold tracking-wider hover:bg-spruce-300 transition-colors uppercase">
            Start Project
          </a>
          <button class="flex sm:hidden h-9 w-9 items-center justify-center bg-onyx-900 border border-onyx-700 text-ivory-100" data-mobile-menu aria-label="Menu">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>
        </div>
      </div>
    </header>

    <main class="pt-20 pb-16 flex-grow">
      <!-- Hero Section -->
      <section class="py-16 md:py-24 px-6 md:px-12 relative">
        <div class="absolute inset-0 technical-grid opacity-[0.05] pointer-events-none"></div>

        <div class="max-w-6xl mx-auto relative z-10">
          <div class="mb-6">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-spruce-400 font-mono text-sm">Services</span>
            </div>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-ivory-100 mb-4">
              What we <span class="text-spruce-400">build</span>
            </h1>
            <p class="text-onyx-300 max-w-2xl text-lg leading-relaxed">
              From frontend interfaces to machine learning pipelines, we deliver end-to-end engineering solutions
              that scale with your business. Every project is custom-built, production-ready, and designed to last.
            </p>
          </div>

          <!-- Quick Nav -->
          <div class="mt-10 flex flex-wrap gap-3">
            {services.map((service: Service) => (
              <a
                href={`#${service.slug}`}
                class="group inline-flex items-center gap-2 px-4 py-2 border border-onyx-700 bg-onyx-900 text-xs font-mono text-onyx-400 uppercase tracking-wider hover:border-spruce-400/30 hover:text-spruce-400 transition-all"
              >
                <span class="material-symbols-outlined text-sm">{service.icon}</span>
                {service.title}
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- Service Sections -->
      {services.map((service: Service, index: number) => {
        const num = String(index + 1).padStart(2, "0");
        const isEven = index % 2 === 0;

        return (
          <section
            id={service.slug}
            class={`py-16 md:py-20 px-6 md:px-12 ${isEven ? 'bg-onyx-900' : ''}`}
          >
            <div class="max-w-6xl mx-auto">
              <div class={`grid grid-cols-1 lg:grid-cols-12 gap-12 items-start`}>
                <!-- Info Column -->
                <div class={`lg:col-span-7 ${!isEven ? 'lg:order-2' : ''}`}>
                  <div class="flex items-center gap-3 mb-4">
                    <span class="text-spruce-400 font-mono text-sm">{num} //</span>
                    <span class="text-onyx-400 font-mono text-xs uppercase tracking-widest">Service</span>
                  </div>

                  <div class="flex items-center gap-3 mb-6">
                    <span class="material-symbols-outlined text-spruce-400 text-3xl">{service.icon}</span>
                    <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold tracking-tight text-ivory-100">
                      {service.title}
                    </h2>
                  </div>

                  <p class="text-onyx-300 text-lg leading-relaxed mb-8">
                    {service.description}
                  </p>

                  <a
                    href="/#contact"
                    class="inline-flex items-center gap-2 px-6 py-3 bg-spruce-400 text-onyx-950 text-xs font-bold tracking-wide uppercase hover:bg-spruce-300 transition-colors"
                  >
                    Discuss This Service
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </a>
                </div>

                <!-- Details Column -->
                <div class={`lg:col-span-5 ${!isEven ? 'lg:order-1' : ''}`}>
                  <div class="border border-onyx-700 bg-onyx-950 p-6 md:p-8">
                    <!-- Deliverables -->
                    <div class="mb-8">
                      <h3 class="font-mono text-[10px] uppercase tracking-widest text-spruce-400 mb-4">Key Deliverables</h3>
                      <ul class="space-y-3">
                        {service.deliverables.map((item) => (
                          <li class="flex items-start gap-3 text-sm text-onyx-300">
                            <span class="text-spruce-400 mt-0.5 shrink-0">
                              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            </span>
                            {item}
                          </li>
                        ))}
                      </ul>
                    </div>

                    <!-- Tech Stack -->
                    <div>
                      <h3 class="font-mono text-[10px] uppercase tracking-widest text-onyx-400 mb-4">Technology Stack</h3>
                      <div class="flex flex-wrap gap-2">
                        {service.tags.map((tag) => (
                          <span class="text-[10px] font-mono border border-onyx-700 px-2.5 py-1 text-onyx-400">
                            {tag}
                          </span>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </section>
        );
      })}

      <!-- CTA Section -->
      <section class="py-16 md:py-24 px-6 md:px-12 bg-onyx-900">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-ivory-100 mb-4">
            Ready to start building?
          </h2>
          <p class="text-onyx-300 text-lg mb-8 max-w-xl mx-auto">
            Tell us about your project and we'll get back to you within 24 hours with a tailored proposal.
          </p>
          <a
            href="/#contact"
            class="inline-flex items-center justify-center px-8 py-4 bg-spruce-400 text-onyx-950 font-bold text-sm tracking-wide uppercase transition-all duration-200 hover:bg-spruce-300"
          >
            Start a Project
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="border-t border-onyx-700 py-8 px-6 md:px-12 mt-auto">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4 text-[10px] font-mono text-onyx-400">
        <div class="flex items-center gap-6">
          <span class="text-spruce-400">2026 Zaftech Solutions</span>
          <span>All rights reserved.</span>
        </div>
        <div class="flex gap-6">
          <a href="/#services" class="hover:text-spruce-400 transition-colors">Capabilities</a>
          <a href="/services" class="text-spruce-400">Services</a>
          <a href="/#contact" class="hover:text-spruce-400 transition-colors">Contact</a>
          <a href="/careers" class="hover:text-spruce-400 transition-colors">Careers</a>
        </div>
      </div>
    </footer>
  </div>

  <!-- Material Icons Link -->
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
</Layout>
