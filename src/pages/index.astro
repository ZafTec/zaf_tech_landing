---
import Layout from "@/layouts/Layout.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import Button from "@/components/ui/Button.astro";
import Kicker from "@/components/ui/Kicker.astro";

export const prerender = true;
---
<Layout
  title="ZafTech — Engineering-precise software"
  description="A small Ethiopian team building production systems for founders in London, Dallas, Berlin. Services and SaaS products."
>
  <div class="min-h-screen flex flex-col">
    <SiteHeader />
    <main class="pt-24 pb-24 grow flex items-center">
      <section class="px-6 md:px-12 w-full">
        <div class="max-w-6xl mx-auto">
          <Kicker num="00" label="Site in rebuild" />
          <h1 class="mt-6 display-tight text-5xl md:text-7xl font-medium text-ivory-100 max-w-3xl">
            We ship software you can bet the quarter on.
          </h1>
          <p class="mt-6 text-onyx-300 max-w-xl text-base md:text-lg leading-relaxed">
            The cinematic rebuild is landing section by section. In the meantime: legal pages are live, and you can reach us directly.
          </p>
          <div class="mt-10 flex flex-wrap gap-3">
            <Button href="mailto:contact@zaftech.co" variant="primary">Book a call</Button>
            <Button href="/services" variant="ghost">See services</Button>
          </div>
        </div>
      </section>
    </main>
    <SiteFooter />
  </div>
</Layout>
