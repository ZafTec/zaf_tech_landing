---
import Layout from "@/layouts/Layout.astro";
import SeoHead from "@/components/SeoHead.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import RevealObserver from "@/components/RevealObserver.astro";

import Hero from "@/components/sections/home/Hero.astro";
import LogoBar from "@/components/sections/home/LogoBar.astro";
import ThreePanel from "@/components/sections/home/ThreePanel.astro";
import ServicesPreview from "@/components/sections/home/ServicesPreview.astro";
import ProductShowcase from "@/components/sections/home/ProductShowcase.astro";
import PortfolioGrid from "@/components/sections/home/PortfolioGrid.astro";
import Testimonials from "@/components/sections/home/Testimonials.astro";
import Process from "@/components/sections/home/Process.astro";
import Contact from "@/components/sections/home/Contact.astro";
import FinalCTA from "@/components/sections/home/FinalCTA.astro";

export const prerender = true;

const title = "ZafTech · Engineering-precise software";
const description = "A small Ethiopian team building production systems for founders in London, Dallas, Berlin. Engineering services and SaaS products you can bet the quarter on.";
---
<Layout title={title} description={description}>
  <Fragment slot="head">
    <SeoHead
      title={title}
      description={description}
      canonicalPath="/"
      jsonLd={{
        "@context": "https://schema.org",
        "@type": "Organization",
        name: "ZafTech Solutions",
        url: "https://zaftech.co",
        logo: "https://zaftech.co/logo/ZAFTECH_LOGO_Dark_Theme.png",
        email: "contact@zaftech.co",
        address: { "@type": "PostalAddress", addressLocality: "Addis Ababa", addressCountry: "ET" },
        sameAs: ["https://github.com/zaftech"],
      }}
    />
  </Fragment>

  <div class="min-h-screen flex flex-col">
    <SiteHeader />
    <main class="grow">
      <Hero />
      <LogoBar />
      <ThreePanel />
      <ServicesPreview />
      <ProductShowcase />
      <PortfolioGrid />
      <Testimonials />
      <Process />
      <Contact />
      <FinalCTA />
    </main>
    <SiteFooter />
  </div>
  <RevealObserver />
</Layout>
