---

---

<section id="contact" class="py-16 md:py-24 relative">
  <div class="absolute inset-0 technical-grid opacity-10 pointer-events-none z-0"></div>

  <div class="max-w-6xl mx-auto px-6 md:px-12 relative z-10">
    <!-- Section Header -->
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-spruce-400 font-mono text-sm">09 //</span>
        <span class="text-onyx-400 font-mono text-xs uppercase tracking-widest">Get in Touch</span>
      </div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-ivory-100 mb-4">
        Contact Us
      </h2>
      <p class="text-onyx-300 max-w-xl text-lg leading-relaxed">
        Ready to start your next project? Our engineering team is here to help you build reliable, scalable solutions.
      </p>
    </div>

    <!-- Contact Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 border border-onyx-700">
      <!-- Contact Info -->
      <div class="lg:col-span-5 bg-onyx-900 border-b lg:border-b-0 lg:border-r border-onyx-700 p-8 md:p-10">
        <div class="space-y-10">
          <div>
            <h3 class="text-xs font-mono text-spruce-400 uppercase tracking-widest mb-8">Contact Information</h3>
            <div class="space-y-6">
              <div class="flex gap-4">
                <div class="text-spruce-400 mt-1">
                  <span class="material-symbols-outlined text-xl">location_on</span>
                </div>
                <div>
                  <p class="text-onyx-400 font-mono text-[10px] uppercase mb-1 tracking-widest">Location</p>
                  <p class="text-ivory-100 text-base leading-relaxed">
                    Addis Ababa, Ethiopia
                  </p>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="text-spruce-400 mt-1">
                  <span class="material-symbols-outlined text-xl">mail</span>
                </div>
                <div>
                  <p class="text-onyx-400 font-mono text-[10px] uppercase mb-1 tracking-widest">Email</p>
                  <p class="text-ivory-100 text-base font-mono">contact@zaftech.co</p>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="text-spruce-400 mt-1">
                  <span class="material-symbols-outlined text-xl">schedule</span>
                </div>
                <div>
                  <p class="text-onyx-400 font-mono text-[10px] uppercase mb-1 tracking-widest">Response Time</p>
                  <p class="text-ivory-100 text-base">Within 24 hours</p>
                </div>
              </div>
            </div>
          </div>

          <div class="h-px bg-onyx-700"></div>

          <div>
            <h3 class="text-xs font-mono text-spruce-400 uppercase tracking-widest mb-6">Connect</h3>
            <div class="grid grid-cols-2 gap-3">
              <a class="group flex items-center justify-between p-4 border border-onyx-700 hover:bg-onyx-800 hover:border-spruce-400/30 transition-all" href="https://github.com/zaftech" target="_blank" rel="noopener noreferrer">
                <span class="font-mono text-xs uppercase text-onyx-400 group-hover:text-ivory-100 transition-colors">GitHub</span>
                <svg viewBox="0 0 24 24" aria-hidden="true" class="w-4 h-4 text-onyx-400 group-hover:text-spruce-400 transition-colors" fill="currentColor">
                  <path d="M12 .5C5.73.5.5 5.74.5 12.02c0 5.1 3.29 9.42 7.86 10.95.58.11.79-.25.79-.56 0-.28-.01-1.2-.02-2.17-3.2.7-3.88-1.37-3.88-1.37-.53-1.36-1.29-1.72-1.29-1.72-1.06-.73.08-.72.08-.72 1.17.08 1.78 1.2 1.78 1.2 1.04 1.78 2.74 1.27 3.41.97.1-.75.4-1.27.73-1.56-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.2-3.09-.12-.3-.52-1.52.12-3.16 0 0 .97-.31 3.18 1.18.92-.26 1.9-.38 2.88-.38s1.96.13 2.88.38c2.2-1.5 3.18-1.18 3.18-1.18.64 1.64.24 2.86.12 3.16.75.8 1.2 1.83 1.2 3.09 0 4.43-2.7 5.4-5.26 5.68.42.36.78 1.07.78 2.16 0 1.56-.01 2.82-.01 3.21 0 .31.21.68.8.56 4.56-1.53 7.85-5.85 7.85-10.95C23.5 5.74 18.27.5 12 .5z"/>
                </svg>
              </a>
              <a class="group flex items-center justify-between p-4 border border-onyx-700 hover:bg-onyx-800 hover:border-spruce-400/30 transition-all" href="https://linkedin.com/company/zaftech" target="_blank" rel="noopener noreferrer">
                <span class="font-mono text-xs uppercase text-onyx-400 group-hover:text-ivory-100 transition-colors">LinkedIn</span>
                <svg viewBox="0 0 24 24" aria-hidden="true" class="w-4 h-4 text-onyx-400 group-hover:text-spruce-400 transition-colors" fill="currentColor">
                  <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.05-1.86-3.05-1.87 0-2.16 1.46-2.16 2.96v5.66H9.33V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.11 20.45H3.56V9h3.55v11.45z"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="lg:col-span-7 bg-onyx-950 p-8 md:p-10">
        <form action="/api/contact" method="post" class="space-y-6" data-contact-form>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="block font-mono text-[10px] uppercase tracking-widest text-onyx-400" for="name">Name</label>
              <input
                class="w-full bg-onyx-900 border border-onyx-700 text-ivory-100 px-4 py-3 placeholder-onyx-500/50 transition-all duration-200"
                id="name"
                name="name"
                placeholder="Your name"
                required
                type="text"
              />
            </div>
            <div class="space-y-2">
              <label class="block font-mono text-[10px] uppercase tracking-widest text-onyx-400" for="email">Email</label>
              <input
                class="w-full bg-onyx-900 border border-onyx-700 text-ivory-100 px-4 py-3 placeholder-onyx-500/50 transition-all duration-200"
                id="email"
                name="email"
                placeholder="name@company.com"
                required
                type="email"
              />
            </div>
          </div>

          <div class="space-y-2">
            <label class="block font-mono text-[10px] uppercase tracking-widest text-onyx-400" for="service">Service</label>
            <div class="relative">
              <select
                class="w-full bg-onyx-900 border border-onyx-700 text-ivory-100 px-4 py-3 appearance-none cursor-pointer transition-all duration-200"
                id="service"
                name="service"
                required
              >
                <option disabled selected value="">Select a service...</option>
                <option value="full-stack">Full-Stack Engineering</option>
                <option value="ml-ai">Machine Learning / AI</option>
                <option value="cloud">Cloud Infrastructure</option>
                <option value="security">Security & DevOps</option>
                <option value="other">Other</option>
              </select>
              <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-onyx-400">
                <span class="material-symbols-outlined">expand_more</span>
              </div>
            </div>
          </div>

          <div class="space-y-2">
            <label class="block font-mono text-[10px] uppercase tracking-widest text-onyx-400" for="message">Project Details</label>
            <textarea
              class="w-full bg-onyx-900 border border-onyx-700 text-ivory-100 px-4 py-3 placeholder-onyx-500/50 resize-none transition-all duration-200"
              id="message"
              name="message"
              placeholder="Tell us about your project requirements..."
              required
              rows="5"
            ></textarea>
          </div>

          <div class="pt-2">
            <button
              class="w-full md:w-auto px-10 py-4 bg-spruce-400 text-onyx-950 font-bold uppercase tracking-widest text-sm hover:bg-spruce-300 transition-all flex items-center justify-center gap-3 group"
              type="submit"
            >
              <span>Send Message</span>
              <span class="material-symbols-outlined text-lg group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </button>
            <p class="mt-4 font-mono text-[10px] text-onyx-500">
              We respond to all inquiries within 24 hours.
            </p>
            <p class="font-mono text-[10px] text-onyx-400 mt-2" data-form-status></p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- Material Icons Link -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
