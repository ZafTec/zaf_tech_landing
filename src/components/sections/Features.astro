---
import type { Feature } from "@/data/content";

interface Props {
  features: Feature[];
}

const { features } = Astro.props;

const featureIcons: string[] = ["layers", "psychology", "dns", "storage"];
---

<section id="features" class="py-16 md:py-24 px-6 md:px-12 bg-onyx-900 border-t border-onyx-700">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-spruce-400 font-mono text-sm">08 //</span>
        <span class="text-onyx-400 font-mono text-xs uppercase tracking-widest">Why Us</span>
      </div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-ivory-100 mb-4">
        Built Different
      </h2>
      <p class="text-onyx-300 max-w-xl text-lg">
        Engineering practices that set us apart.
      </p>
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map((feature: Feature, index: number) => {
        const icon = featureIcons[index] || "check_circle";
        
        return (
          <div class="group relative flex flex-col p-6 bg-onyx-950 border border-onyx-700 hover:border-spruce-400/30 transition-all duration-200">
            <!-- Hover Top Border Accent -->
            <div class="absolute top-0 left-0 w-full h-0.5 bg-spruce-400 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>

            <div class="flex justify-between items-start mb-4">
              <span class="font-mono text-xs text-onyx-500 group-hover:text-spruce-400 transition-colors">[ 0{index + 1} ]</span>
              <span class="material-symbols-outlined text-onyx-500 group-hover:text-spruce-400 text-2xl transition-colors">{icon}</span>
            </div>

            <h3 class="text-lg font-bold text-ivory-100 mb-3 group-hover:text-spruce-400 transition-colors">
              {feature.title}
            </h3>
            
            <p class="text-onyx-400 text-sm leading-relaxed">
              {feature.body}
            </p>
          </div>
        );
      })}
    </div>

    <!-- Stats Row -->
    <div class="mt-12 grid grid-cols-2 md:grid-cols-4 gap-6">
      {[
        { label: "Projects Deployed", value: "50+" },
        { label: "Uptime Guarantee", value: "99.9%" },
        { label: "Response Time", value: "<24h" },
        { label: "Code Coverage", value: "95%" },
      ].map((stat) => (
        <div class="text-center">
          <p class="text-2xl md:text-3xl font-bold text-spruce-400">{stat.value}</p>
          <p class="font-mono text-[10px] text-onyx-400 mt-1 uppercase tracking-widest">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Material Icons Link -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
