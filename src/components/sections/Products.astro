---
import type { Product } from "@/data/content";
import { Image } from "astro:assets";

interface Props {
  products: Product[];
}

const { products } = Astro.props;
---

<section id="products" class="py-16 md:py-24 bg-onyx-900">
  <div class="max-w-6xl mx-auto px-6 md:px-12">
    <!-- Section Header -->
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-spruce-400 font-mono text-sm">04 //</span>
        <span class="text-onyx-400 font-mono text-xs uppercase tracking-widest">Our Products</span>
      </div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-ivory-100 mb-4">
        Proprietary Products
      </h2>
      <p class="text-onyx-300 max-w-xl text-lg">
        Enterprise solutions built in-house, battle-tested in production.
      </p>
    </div>

    <div class="relative" id="products-gallery">
      <!-- Navigation Buttons -->
      <button
        type="button"
        class="absolute left-0 md:-left-6 top-1/2 -translate-y-1/2 z-20 w-12 h-12 bg-onyx-800 border border-onyx-700 flex items-center justify-center text-ivory-100 hover:bg-onyx-700 hover:border-spruce-400 hover:text-spruce-400 transition-all duration-300"
        id="scroll-prev"
        aria-label="Previous product"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>

      <button
        type="button"
        class="absolute right-0 md:-right-6 top-1/2 -translate-y-1/2 z-20 w-12 h-12 bg-onyx-800 border border-onyx-700 flex items-center justify-center text-ivory-100 hover:bg-onyx-700 hover:border-spruce-400 hover:text-spruce-400 transition-all duration-300"
        id="scroll-next"
        aria-label="Next product"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>

      <!-- Carousel Track -->
      <div class="overflow-hidden" id="carousel-viewport">
        <div
          class="flex transition-transform duration-500 ease-out"
          id="carousel-track"
        >
          {products.map((product) => (
            <div class="product-slide shrink-0 w-[85%] md:w-200 snap-center px-2">
              <div class="border border-onyx-700 bg-onyx-900 overflow-hidden hover:border-spruce-400/30 transition-colors duration-300">
                <div class="relative w-full aspect-video">
                  {product.imageLight ? (
                    <>
                      <Image
                        src={product.image}
                        alt={`${product.name} - ${product.tagline}`}
                        class="w-full h-full object-cover object-top product-image--dark"
                        widths={[640, 960, 1280, 1600, 1920]}
                        sizes="(max-width: 768px) 85vw, 800px"
                      />
                      <Image
                        src={product.imageLight}
                        alt={`${product.name} - ${product.tagline}`}
                        class="w-full h-full object-cover object-top product-image--light"
                        widths={[640, 960, 1280, 1600, 1920]}
                        sizes="(max-width: 768px) 85vw, 800px"
                      />
                    </>
                  ) : (
                    <Image
                      src={product.image}
                      alt={`${product.name} - ${product.tagline}`}
                      class="w-full h-full object-cover object-top"
                      widths={[640, 960, 1280, 1600, 1920]}
                      sizes="(max-width: 768px) 85vw, 800px"
                    />
                  )}

                  <div class="absolute inset-0 product-overlay pointer-events-none" aria-hidden="true"></div>
                  <div class="absolute inset-0 product-overlay-gradient pointer-events-none" aria-hidden="true"></div>

                  <div class="absolute bottom-0 left-0 right-0 p-5 md:p-6 product-text-overlay">
                    <div class="max-w-2xl">
                      <p class="font-mono text-[10px] text-spruce-400 uppercase tracking-widest mb-2">{product.tagline}</p>
                      <h3 class="text-lg md:text-xl lg:text-2xl font-bold text-ivory-100 mb-2">{product.headline}</h3>
                      <p class="hidden md:block text-sm text-onyx-300 leading-relaxed mb-4">{product.description}</p>

                      <a
                        href={product.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-2 px-4 py-2 bg-spruce-400 text-onyx-950 text-xs font-bold tracking-wide hover:bg-spruce-300 transition-colors uppercase"
                      >
                        Explore
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Dots -->
      <div class="flex justify-center items-center gap-2 mt-6">
        {products.map((_, index) => (
          <button
            type="button"
            class={`dot w-2 h-2 transition-all duration-300 hover:bg-spruce-400/50 ${index === 0 ? 'active bg-spruce-400 w-6' : 'bg-onyx-600'}`}
            data-index={index}
            aria-label={`Go to product ${index + 1}`}
          />
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .dot.active {
    background-color: var(--color-spruce-400);
    width: 1.5rem;
  }

  #carousel-track {
    will-change: transform;
  }
</style>

<script is:inline>
  (function() {
    const track = document.getElementById('carousel-track');
    const nextBtn = document.getElementById('scroll-next');
    const prevBtn = document.getElementById('scroll-prev');
    const dots = document.querySelectorAll('#products-gallery .dot');

    if (!track || !track.children.length) return;

    const count = track.children.length;
    let current = 0;

    function updateCarousel() {
      const slide = track.children[0];
      if (!slide) return;
      const width = slide.offsetWidth;
      track.style.transform = 'translateX(-' + (current * width) + 'px)';
      dots.forEach(function(d, i) {
        d.classList.toggle('active', i === current);
        d.classList.toggle('bg-spruce-400', i === current);
        d.classList.toggle('w-6', i === current);
        d.classList.toggle('bg-onyx-600', i !== current);
        d.classList.toggle('w-2', i !== current);
      });
    }

    if (nextBtn) nextBtn.onclick = function() {
      current = (current + 1) % count;
      updateCarousel();
    };

    if (prevBtn) prevBtn.onclick = function() {
      current = (current - 1 + count) % count;
      updateCarousel();
    };

    dots.forEach(function(d, i) {
      d.onclick = function() {
        current = i;
        updateCarousel();
      };
    });

    var resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(updateCarousel, 100);
    });
  })();
</script>
