---
import type { Service } from "@/data/content";

interface Props {
  services: Service[];
}

const { services } = Astro.props;

const serviceIcons: Record<string, string> = {
  "UI/UX & Frontend": "palette",
  "Backend & Infrastructure": "dns",
  "Machine Learning & AI": "psychology",
};

const serviceTags: Record<string, string[]> = {
  "UI/UX & Frontend": ["React", "Next.js", "TypeScript"],
  "Backend & Infrastructure": ["Node", "PostgreSQL", "Kubernetes"],
  "Machine Learning & AI": ["PyTorch", "TensorFlow", "OpenAI"],
};
---

<section id="services" class="py-16 md:py-24 px-6 md:px-12 bg-onyx-900">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-spruce-400 font-mono text-sm">02 //</span>
        <span class="text-onyx-400 font-mono text-xs uppercase tracking-widest">What We Offer</span>
      </div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-ivory-100 mb-4">
        Capabilities
      </h2>
      <p class="text-onyx-300 max-w-xl text-lg">
        End-to-end solutions across the entire technology stack.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {services.map((service: Service, index: number) => {
        const num = String(index + 1).padStart(2, "0");
        const icon = serviceIcons[service.title] || "terminal";
        const tags = serviceTags[service.title] || [];
        
        return (
          <div class="group relative flex flex-col p-8 bg-onyx-900 border border-onyx-700 hover:border-spruce-400/30 transition-all duration-200">
            <!-- Hover Top Border Accent -->
            <div class="absolute top-0 left-0 w-full h-0.5 bg-spruce-400 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
            
            <div class="flex justify-between items-start mb-6">
              <span class="font-mono text-xs text-onyx-500 group-hover:text-spruce-400 transition-colors">[ {num} ]</span>
              <span class="material-symbols-outlined text-onyx-500 group-hover:text-spruce-400 text-3xl transition-colors">{icon}</span>
            </div>
            
            <h3 class="text-xl font-bold text-ivory-100 mb-4 group-hover:text-spruce-400 transition-colors">
              {service.title}
            </h3>
            
            <p class="text-onyx-400 text-sm leading-relaxed mb-6 flex-grow">
              {service.body}
            </p>
            
            <!-- Tech Tags -->
            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="text-[10px] font-mono border border-onyx-700 px-2 py-1 text-onyx-400 group-hover:border-onyx-600 transition-colors">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<!-- Material Icons Link -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
