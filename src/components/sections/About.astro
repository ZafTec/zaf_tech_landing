---

---

<section id="about" class="py-16 md:py-24 px-4 sm:px-6 md:px-12 lg:px-24 relative overflow-hidden">
  <!-- Background Grid -->
  <div class="absolute inset-0 bg-grid-pattern opacity-5 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    <!-- Section Header -->
    <div class="mb-8 flex flex-col sm:flex-row sm:items-end justify-between border-b border-border-dim pb-4">
      <h2 class="text-primary font-mono text-lg sm:text-xl tracking-tight">05 // ABOUT_PROTOCOL</h2>
      <span class="hidden sm:block text-ink-muted font-mono text-xs text-right max-w-[200px] leading-tight mt-2 sm:mt-0">
        &lt;mission_statement&gt;<br/>
        initialized
      </span>
    </div>

    <div class="grid gap-8 lg:gap-12 lg:grid-cols-2 items-center">
      <!-- Content -->
      <div class="space-y-6">
        <div class="space-y-4">
          <p class="text-ink-muted font-mono text-sm">&gt; loading company_profile...</p>
          <h3 class="text-3xl md:text-4xl font-bold text-ink leading-tight">
            Engineering teams that ship production systems.
          </h3>
          <p class="text-base text-ink-muted leading-relaxed">
            We combine deep technical expertise with product thinking. Every engagement includes senior engineers, iterative delivery, and maintainable architecture. No marketing fluff - just code that works.
          </p>
        </div>

        <!-- Tech Stack Grid -->
        <div class="grid grid-cols-2 gap-3">
          {[
            { icon: "code", label: "Full-Stack Engineering" },
            { icon: "psychology", label: "Machine Learning" },
            { icon: "cloud", label: "Cloud Infrastructure" },
            { icon: "security", label: "Security & DevOps" },
          ].map((item) => (
            <div class="group flex items-center gap-3 p-4 border border-border-dim bg-void hover:border-primary/30 hover:bg-onyx transition-all duration-200">
              <span class="material-symbols-outlined text-primary text-xl">{item.icon}</span>
              <span class="font-mono text-xs text-ink group-hover:text-primary transition-colors">{item.label}</span>
            </div>
          ))}
        </div>

        <!-- Console Output -->
        <div class="font-mono text-xs text-ink-muted space-y-1 border-l-2 border-primary/30 pl-4">
          <p>&gt; stack: [REACT, NODE, PYTHON, AWS]</p>
          <p>&gt; methodology: AGILE_ITERATIVE</p>
          <p>&gt; status: ACCEPTING_NEW_CLIENTS</p>
        </div>
      </div>

      <!-- Terminal Window Visual -->
      <div class="relative">
        <div class="bg-onyx border border-border-dim shadow-2xl">
          <!-- Window Header -->
          <div class="bg-[#222] border-b border-border-dim px-4 py-2 flex items-center gap-2">
            <div class="w-3 h-3 rounded-full bg-[#FF5F56]"></div>
            <div class="w-3 h-3 rounded-full bg-[#FFBD2E]"></div>
            <div class="w-3 h-3 rounded-full bg-[#27C93F]"></div>
            <span class="ml-auto font-mono text-xs text-ink-muted">about.md</span>
          </div>

          <!-- Content -->
          <div class="p-6 font-mono text-sm space-y-3">
            <p class="text-ink-muted"># ZAFTECH MISSION</p>
            <p class="text-ink">
              <span class="text-primary">const</span> mission = <span class="text-green-400">"Build systems that scale"</span>;
            </p>
            <p class="text-ink-muted mt-4">// Core Values</p>
            <p class="text-ink">
              <span class="text-purple-400">export</span> <span class="text-primary">const</span> values = {"{"}
            </p>
            <p class="text-ink pl-4">precision: <span class="text-yellow-300">true</span>,</p>
            <p class="text-ink pl-4">scalability: <span class="text-yellow-300">true</span>,</p>
            <p class="text-ink pl-4">security: <span class="text-yellow-300">MAX_INT</span>,</p>
            <p class="text-ink pl-4">marketing_fluff: <span class="text-red-400">false</span></p>
            <p class="text-ink">{"}"}</p>
            <div class="mt-4 flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
              <span class="text-primary">Ready to deploy.</span>
            </div>
          </div>
        </div>

        <!-- Corner Accents -->
        <div class="absolute -top-2 -left-2 w-4 h-4 border-l border-t border-primary/50"></div>
        <div class="absolute -bottom-2 -right-2 w-4 h-4 border-r border-b border-primary/50"></div>
      </div>
    </div>
  </div>
</section>

<!-- Material Icons Link -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
