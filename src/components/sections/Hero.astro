---
import Threads from "@/components/Threads/Threads.jsx";
---

<section id="hero" class="relative w-full overflow-hidden" style="min-height: calc(100vh - 64px); max-height: calc(100vh - 64px);">
  <!-- Threads Background with Glass Effect -->
  <div class="absolute inset-0 z-0">
    <!-- Base background -->
    <div class="absolute inset-0 bg-onyx-950"></div>
    
    <!-- Threads Animation - mouse interactive with higher visibility -->
    <div class="absolute inset-0 opacity-80">
      <Threads
        client:load
        color={[0.55, 0.69, 0.74]}
        amplitude={1.2}
        distance={0.5}
        enableMouseInteraction={true}
      />
    </div>
    
    <!-- Glass overlay - subtle tint, threads clearly visible -->
    <div class="absolute inset-0 bg-onyx-950/30 backdrop-blur-[1px]"></div>
  </div>

  <div class="relative z-10 h-full flex flex-col justify-center px-6 md:px-12 lg:px-24 py-16" style="min-height: calc(100vh - 64px);">
    <div class="max-w-6xl mx-auto w-full">
      <!-- Section Label -->
      <div class="flex items-center gap-3 mb-6 reveal">
        <span class="text-spruce-400 font-mono text-sm">01 //</span>
        <span class="text-onyx-400 font-mono text-xs uppercase tracking-widest">Engineering Excellence</span>
      </div>

      <!-- Main Headline -->
      <div class="mb-6 reveal delay-1">
        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.1] text-ivory-100">
          Build systems<br/>
          <span class="text-spruce-400">that scale</span>
        </h1>
      </div>

      <!-- Subheadline -->
      <p class="text-base sm:text-lg text-onyx-300 max-w-xl leading-relaxed mb-10 reveal delay-2">
        Full-stack engineering and machine learning solutions for organizations that demand reliability, 
        security, and performance at scale.
      </p>

      <!-- CTA Group -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 reveal delay-3">
        <a
          href="#contact"
          class="inline-flex items-center justify-center px-8 py-4 bg-spruce-400 text-onyx-950 font-bold text-sm tracking-wide uppercase transition-all duration-200 hover:bg-spruce-300"
        >
          Start a Project
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a 
          href="#services" 
          class="group flex items-center gap-2 text-ivory-100 text-sm hover:text-spruce-400 transition-colors py-2"
        >
          <span class="border-b border-transparent group-hover:border-spruce-400">View Capabilities</span>
        </a>
      </div>

      <!-- Stats Row -->
      <div class="mt-16 pt-8 border-t border-onyx-800 grid grid-cols-2 md:grid-cols-4 gap-6 reveal delay-4">
        <div>
          <span class="block text-2xl md:text-3xl font-bold text-spruce-400">50+</span>
          <span class="text-[10px] font-mono text-onyx-400 uppercase tracking-widest">Projects Delivered</span>
        </div>
        <div>
          <span class="block text-2xl md:text-3xl font-bold text-spruce-400">99.9%</span>
          <span class="text-[10px] font-mono text-onyx-400 uppercase tracking-widest">Uptime</span>
        </div>
        <div>
          <span class="block text-2xl md:text-3xl font-bold text-spruce-400">&lt;24h</span>
          <span class="text-[10px] font-mono text-onyx-400 uppercase tracking-widest">Response Time</span>
        </div>
        <div>
          <span class="block text-2xl md:text-3xl font-bold text-spruce-400">4+</span>
          <span class="text-[10px] font-mono text-onyx-400 uppercase tracking-widest">Years Experience</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Corner Decorations -->
  <div class="absolute top-8 left-8 w-4 h-4 border-l border-t border-onyx-600 z-20"></div>
  <div class="absolute top-8 right-8 w-4 h-4 border-r border-t border-onyx-600 z-20"></div>
  <div class="absolute bottom-8 left-8 w-4 h-4 border-l border-b border-onyx-600 z-20"></div>
  <div class="absolute bottom-8 right-8 w-4 h-4 border-r border-b border-onyx-600 z-20"></div>
</section>
