---
import { stats } from "@/data/content";
---

<section id="hero" class="relative w-full overflow-hidden bg-onyx-950" style="min-height: calc(100vh - 64px); max-height: calc(100vh - 64px);">
  <!-- Canvas Background -->
  <canvas id="hero-waves" class="absolute inset-0 w-full h-full z-0 pointer-events-none opacity-70"></canvas>

  <div class="relative z-10 h-full flex flex-col justify-center px-6 md:px-12 lg:px-24 py-16" style="min-height: calc(100vh - 64px);">
    <div class="max-w-6xl mx-auto w-full">
      <!-- Section Label -->
      <div class="flex items-center gap-3 mb-6 reveal">
        <span class="text-spruce-400 font-mono text-sm">01 //</span>
        <span class="text-onyx-400 font-mono text-xs uppercase tracking-widest">Engineering Excellence</span>
      </div>

      <!-- Main Headline -->
      <div class="mb-6 reveal delay-1">
        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.1] text-ivory-100">
          Build systems<br/>
          <span class="text-spruce-400">that scale</span>
        </h1>
      </div>

      <!-- Subheadline -->
      <p class="text-base sm:text-lg text-onyx-300 max-w-xl leading-relaxed mb-10 reveal delay-2">
        Full-stack engineering and machine learning solutions for organizations that demand reliability,
        security, and performance at scale.
      </p>

      <!-- CTA Group -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 reveal delay-3">
        <a
          href="#contact"
          class="hero-cta-pulse inline-flex items-center justify-center px-8 py-4 bg-spruce-400 text-onyx-950 font-bold text-sm tracking-wide uppercase transition-all duration-200 hover:bg-spruce-300"
        >
          Start a Project
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="#services"
          class="group flex items-center gap-2 text-ivory-100 text-sm hover:text-spruce-400 transition-colors py-2"
        >
          <span class="border-b border-transparent group-hover:border-spruce-400">View Capabilities</span>
        </a>
      </div>

      <!-- Stats Row -->
      <div class="mt-16 pt-8 border-t border-onyx-800 grid grid-cols-2 md:grid-cols-4 gap-6 reveal delay-4">
        {stats.map((stat) => (
          <div>
            <span class="block text-2xl md:text-3xl font-bold text-spruce-400">{stat.value}</span>
            <span class="text-[10px] font-mono text-onyx-400 uppercase tracking-widest">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Corner Decorations -->
  <div class="absolute top-8 left-8 w-4 h-4 border-l border-t border-onyx-600 z-20"></div>
  <div class="absolute top-8 right-8 w-4 h-4 border-r border-t border-onyx-600 z-20"></div>
  <div class="absolute bottom-8 left-8 w-4 h-4 border-l border-b border-onyx-600 z-20"></div>
  <div class="absolute bottom-8 right-8 w-4 h-4 border-r border-b border-onyx-600 z-20"></div>
</section>

<script>
  function initWaves() {
    const canvas = document.getElementById('hero-waves') as HTMLCanvasElement | null;
    const section = document.getElementById('hero') as HTMLElement | null;

    if (!canvas || !section) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let width = 0;
    let height = 0;
    let mouse = { x: -1000, y: -1000, targetX: -1000, targetY: -1000 };
    let time = 0;
    let animationFrameId: number;

    const resize = () => {
      width = section.clientWidth;
      height = section.clientHeight;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = width * dpr;
      canvas.height = height * dpr;
      ctx.scale(dpr, dpr);
    };

    window.addEventListener('resize', resize);
    resize();

    const handleMouseMove = (e: MouseEvent) => {
      const rect = section.getBoundingClientRect();
      mouse.targetX = e.clientX - rect.left;
      mouse.targetY = e.clientY - rect.top;
    };

    const handleMouseLeave = () => {
      mouse.targetX = -1000;
      mouse.targetY = -1000;
    };

    section.addEventListener('mousemove', handleMouseMove);
    section.addEventListener('mouseleave', handleMouseLeave);

    // Check for light mode preference
    const isLight = window.matchMedia('(prefers-color-scheme: light)').matches;
    const colorRGB = isLight ? '30, 140, 130' : '45, 212, 191';

    const config = {
      waves: 12,
      speed: 0.004,
      baseAmplitude: 160,
      frequency: 0.003,
      mouseRadius: 300,
      mouseForce: 60,
      lensStrength: 40,
    };

    const animate = () => {
      animationFrameId = requestAnimationFrame(animate);

      time += 1;
      ctx.clearRect(0, 0, width, height);

      // Smooth mouse interpolation
      mouse.x += (mouse.targetX - mouse.x) * 0.08;
      mouse.y += (mouse.targetY - mouse.y) * 0.08;

      // Draw waves from back to front
      for (let i = 0; i < config.waves; i++) {
        ctx.beginPath();

        const progress = i / (config.waves - 1);

        // More visible opacity range
        const alpha = 0.04 + progress * 0.35;
        ctx.strokeStyle = `rgba(${colorRGB}, ${alpha})`;
        ctx.lineWidth = 0.8 + progress * 2;

        const frequency = config.frequency + i * 0.0004;
        const phase = time * config.speed + i * (Math.PI / 5);

        // Draw with finer step for smoother curves
        for (let x = 0; x <= width; x += 4) {
          const nx = x / width;
          const expandFactor = Math.pow(nx, 2.2);
          const spread = (progress - 0.5) * expandFactor * height * 0.9;

          // Multi-frequency wave for organic feel
          let y = height / 2
            + Math.sin(x * frequency + phase) * config.baseAmplitude * expandFactor
            + Math.sin(x * frequency * 0.5 + phase * 1.3) * config.baseAmplitude * 0.3 * expandFactor
            + spread;

          // Magnifying lens distortion on mouse hover
          const dx = x - mouse.x;
          const dy = y - mouse.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          const maxDist = config.mouseRadius;

          if (dist < maxDist) {
            const normalizedDist = dist / maxDist;
            // Smooth lens curve: strong push near center, fades at edges
            const lensFactor = Math.pow(1 - normalizedDist, 3);
            // Push outward from cursor with lens-like magnification
            const pushX = (dx / (dist || 1)) * lensFactor * config.lensStrength * expandFactor;
            const pushY = (dy / (dist || 1)) * lensFactor * config.mouseForce * expandFactor;
            y += pushY;
            // Slight horizontal warping for glass-like feel
            const warpedX = x + pushX * 0.3;

            if (x === 0) {
              ctx.moveTo(warpedX, y);
            } else {
              ctx.lineTo(warpedX, y);
            }
          } else {
            if (x === 0) {
              ctx.moveTo(x, y);
            } else {
              ctx.lineTo(x, y);
            }
          }
        }
        ctx.stroke();
      }
    };

    animate();

    // Cleanup
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animationFrameId);
      window.removeEventListener('resize', resize);
      section.removeEventListener('mousemove', handleMouseMove);
      section.removeEventListener('mouseleave', handleMouseLeave);
    }, { once: true });
  }

  initWaves();
  document.addEventListener('astro:page-load', initWaves);
</script>
