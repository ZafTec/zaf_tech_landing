---
import { Image } from "astro:assets";
import { team, roleConfigs } from "@/data/content";
import type { TeamMember, RoleConfig } from "@/data/content";
---

<section id="team" class="relative">
  <!-- Sticky Section Header with Glass Effect -->
  <div class="sticky top-16 z-40 border-b border-onyx-700 bg-onyx-950/80 backdrop-blur-md">
    <div class="max-w-6xl mx-auto px-6 md:px-12 py-6 flex flex-col md:flex-row md:items-end justify-between gap-4">
      <div>
        <div class="flex items-center gap-3 mb-2">
          <span class="text-spruce-400 font-mono text-sm">06 //</span>
          <span class="text-onyx-400 font-mono text-xs uppercase tracking-widest">Our Team</span>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-ivory-100">The Operators</h2>
      </div>
      <div class="font-mono text-xs text-onyx-400 hidden md:block">
        {team.length} operators
      </div>
    </div>
  </div>

  <!-- Team Grid -->
  <div class="max-w-6xl mx-auto px-6 md:px-12 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
      {team.map((member: TeamMember) => {
        const config: RoleConfig = roleConfigs[member.role] || { icon: "person", label: "Operator", skills: [] };
        
        return (
          <article class="group relative flex flex-col bg-onyx-900 border border-onyx-700 hover:border-spruce-400/30 transition-all duration-300 overflow-hidden">
            <!-- Hover Top Border Accent -->
            <div class="absolute top-0 left-0 w-full h-0.5 bg-spruce-400 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left z-20"></div>

            <!-- Header -->
            <div class="p-5 flex justify-between items-start">
              <div class="flex flex-col gap-1">
                <span class="font-mono text-[10px] text-onyx-400 uppercase tracking-widest">{config.label}</span>
              </div>
              <span class="material-symbols-outlined text-onyx-500 group-hover:text-spruce-400 transition-colors text-xl">{config.icon}</span>
            </div>

            <!-- Image Container -->
            <div class="relative h-56 overflow-hidden">
              <Image
                src={member.image}
                alt={member.name}
                width={400}
                height={500}
                format="webp"
                quality={70}
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover filter-grayscale"
                sizes="(min-width: 1280px) 25vw, (min-width: 768px) 50vw, 100vw"
              />
              <div class="absolute inset-0 bg-onyx-950/40 group-hover:bg-onyx-950/20 transition-colors"></div>
            </div>

            <!-- Content Footer -->
            <div class="p-5 border-t border-onyx-700">
              <h3 class="text-lg font-bold text-ivory-100 mb-3 group-hover:text-spruce-400 transition-colors">
                {member.name}
              </h3>
              <div class="flex flex-wrap gap-2">
                {config.skills.slice(0, 3).map((tag) => (
                  <span class="font-mono text-[10px] text-onyx-400 border border-onyx-700 px-2 py-0.5 group-hover:border-onyx-600 transition-colors">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </article>
        );
      })}

      <!-- Career / Join Card -->
      <article class="group relative flex flex-col justify-center items-center bg-onyx-900/50 border border-dashed border-onyx-600 hover:border-spruce-400/50 transition-all duration-300 text-center p-8 min-h-100">
        <div class="relative z-10 flex flex-col items-center gap-5">
          <div class="w-16 h-16 rounded-full border border-onyx-600 flex items-center justify-center group-hover:border-spruce-400 group-hover:bg-onyx-800 transition-all duration-300">
            <span class="material-symbols-outlined text-onyx-500 group-hover:text-spruce-400 text-3xl transition-colors">add</span>
          </div>
          
          <div class="space-y-2">
            <span class="font-mono text-[10px] text-spruce-400 uppercase tracking-widest">We're Hiring</span>
            <h3 class="text-xl font-bold text-ivory-100">Join Our Team</h3>
            <p class="font-mono text-xs text-onyx-400 max-w-50 mx-auto">
              Looking for talented engineers to join our mission.
            </p>
          </div>
          
          <a 
            href="/careers" 
            class="mt-2 font-mono text-xs text-spruce-400 hover:text-ivory-100 border border-spruce-400/50 hover:bg-spruce-400 hover:border-spruce-400 px-5 py-2.5 transition-all duration-300 uppercase tracking-wider"
          >
            View Openings
          </a>
        </div>
      </article>
    </div>
  </div>
</section>

<!-- Material Icons Link -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
