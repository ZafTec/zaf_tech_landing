---
import Button from "@/components/ui/Button.astro";
---
<section class="border-b border-onyx-800">
  <div class="px-6 md:px-12 py-28 md:py-36">
    <div class="max-w-4xl mx-auto text-center reveal-up">
      <h2 class="display-tight text-4xl md:text-6xl font-medium text-ivory-100">
        Let's make something<br class="hidden md:block" /> worth shipping.
      </h2>
      <p class="mt-6 text-onyx-300 text-base md:text-lg">
        15 minutes. No slide deck. We'll tell you if we're the right fit.
      </p>
      <div class="mt-10 flex justify-center">
        <Button href="mailto:contact@zaftech.co?subject=Book%20a%2015-min%20call" variant="primary">Book a 15-min call</Button>
      </div>
      <p class="mt-6 font-mono text-[10px] uppercase tracking-widest text-onyx-500">
        or email <a href="mailto:contact@zaftech.co" class="text-spruce-400 hover:text-spruce-300">contact@zaftech.co</a>
      </p>
    </div>
  </div>
</section>
