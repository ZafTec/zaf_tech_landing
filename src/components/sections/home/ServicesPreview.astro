---
import Kicker from "@/components/ui/Kicker.astro";

const items = [
  { n: "01", title: "Full-stack engineering", body: "React, Next.js, Go, Python, Postgres.", tags: ["React", "Go", "Postgres"] },
  { n: "02", title: "AI & LLM integration", body: "Custom RAG, agents, fine-tuning pipelines.", tags: ["OpenAI", "LangChain", "pgvector"] },
  { n: "03", title: "Cloud & DevOps", body: "AWS/GCP, Kubernetes, Terraform, CI/CD.", tags: ["AWS", "Terraform", "K8s"] },
  { n: "04", title: "UI/UX & frontend", body: "Design systems, motion, production polish.", tags: ["Figma", "Tailwind", "Motion"] },
  { n: "05", title: "WordPress & CMS", body: "Custom themes, WooCommerce, headless.", tags: ["WordPress", "PHP", "REST"] },
  { n: "06", title: "Security & audits", body: "Pen-testing, hardening, threat modelling.", tags: ["OWASP", "SonarQube", "Vault"] },
];
---
<section id="services" class="border-b border-onyx-800">
  <div class="px-6 md:px-12 py-24 md:py-28">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-end justify-between gap-6 flex-wrap">
        <div>
          <Kicker num="04" label="Services" />
          <h2 class="mt-4 display-tight text-3xl md:text-4xl font-medium text-ivory-100">What we build.</h2>
        </div>
        <a href="/services" class="font-mono text-[10px] uppercase tracking-widest text-onyx-400 hover:text-spruce-400 transition-colors">All services →</a>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-onyx-800 border border-onyx-800">
        {items.map((s) => (
          <a href={`/services#${s.n}`} class="card-accent-bar reveal-up block p-7 bg-onyx-950 hover:bg-onyx-900/70 transition-colors">
            <span class="font-mono text-[10px] text-spruce-400 tracking-widest">/ {s.n}</span>
            <h3 class="mt-5 text-lg font-medium text-ivory-100">{s.title}</h3>
            <p class="mt-2 text-onyx-300 text-sm leading-relaxed">{s.body}</p>
            <div class="mt-6 flex flex-wrap gap-1.5">
              {s.tags.map((t) => (
                <span class="font-mono text-[10px] text-onyx-400 border border-onyx-800 px-2 py-0.5">{t}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
