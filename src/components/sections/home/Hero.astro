---
import Button from "@/components/ui/Button.astro";
import Kicker from "@/components/ui/Kicker.astro";
import Threads from "@/components/Threads.jsx";
---
<section
  class="relative isolate overflow-hidden bg-onyx-950"
  style="min-height: 100dvh;"
>
  <!-- Interactive canvas, sits behind content -->
  <div class="absolute inset-0 z-0 pointer-events-auto">
    <Threads client:idle amplitude={1.1} distance={0.05} enableMouseInteraction={true} />
  </div>

  <!-- Vignette to keep headline readable over canvas -->
  <div
    class="absolute inset-0 z-10 pointer-events-none hero-vignette"
    aria-hidden="true"
  ></div>

  <!-- Content column -->
  <div class="relative z-20 flex flex-col min-h-[100dvh] px-6 md:px-12 pt-28 pb-16">
    <div class="max-w-6xl mx-auto w-full grow flex items-center">
      <div class="max-w-3xl reveal-up">
        <Kicker num="01" label="Engineering" />
        <h1 class="mt-6 display-tight text-5xl md:text-7xl lg:text-[96px] font-medium text-ivory-100">
          We ship software<br />
          you can bet<br />
          the quarter on.
        </h1>
        <p class="mt-8 text-onyx-200 max-w-xl text-base md:text-lg leading-relaxed">
          A small team out of Addis Ababa building production systems for founders in London, Dallas, and Berlin.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <Button href="mailto:contact@zaftech.co?subject=Book%20a%20call" variant="primary">Book a call</Button>
          <Button href="#portfolio" variant="ghost">See our work</Button>
        </div>
      </div>
    </div>

    <!-- Bottom stat strip -->
    <div class="max-w-6xl mx-auto w-full mt-10 pt-6 border-t border-onyx-800/60 flex flex-wrap items-center justify-between gap-4 reveal-up" style="--reveal-delay: 160ms;">
      <dl class="flex flex-wrap gap-x-6 gap-y-2 font-mono text-xs text-onyx-300">
        <div class="flex items-center gap-2"><span class="text-spruce-400">50+</span> shipped</div>
        <span class="text-onyx-700">/</span>
        <div class="flex items-center gap-2"><span class="text-spruce-400">99.9%</span> uptime</div>
        <span class="text-onyx-700">/</span>
        <div class="flex items-center gap-2"><span class="text-spruce-400">&lt; 24h</span> reply</div>
      </dl>
      <span class="font-mono text-[10px] uppercase tracking-widest text-onyx-500">// scroll</span>
    </div>
  </div>
</section>

<style>
  /* Dark mode default: vignette gently tints inner-left for legibility */
  .hero-vignette {
    background:
      radial-gradient(ellipse at 20% 40%, rgba(12, 15, 13, 0.55) 0%, rgba(12, 15, 13, 0) 55%),
      linear-gradient(to right, rgba(12, 15, 13, 0.65) 0%, rgba(12, 15, 13, 0) 60%),
      linear-gradient(to top, rgba(12, 15, 13, 0.35) 0%, rgba(12, 15, 13, 0) 30%);
  }
  @media (prefers-color-scheme: light) {
    .hero-vignette {
      background:
        radial-gradient(ellipse at 20% 40%, rgba(255, 255, 255, 0.7) 0%, rgba(255, 255, 255, 0) 55%),
        linear-gradient(to right, rgba(255, 255, 255, 0.7) 0%, rgba(255, 255, 255, 0) 60%),
        linear-gradient(to top, rgba(255, 255, 255, 0.35) 0%, rgba(255, 255, 255, 0) 30%);
    }
  }
</style>
