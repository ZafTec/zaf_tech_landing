---
import { Image } from "astro:assets";
import heroImage from "@/assets/hero.png";
import Button from "@/components/ui/Button.astro";
import Kicker from "@/components/ui/Kicker.astro";
---
<section
  class="relative isolate overflow-hidden bg-onyx-950"
  style="min-height: 100dvh;"
  data-hero
  data-hero-src={heroImage.src}
  data-ga-section="hero"
>
  <!-- Background image layer -->
  <div class="absolute inset-0 z-0">
    <Image
      src={heroImage}
      alt="Abstract architectural background"
      class="w-full h-full object-cover"
      width={1920}
      height={1080}
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <!-- WebGL layer: gray overlay that shades away under the cursor. -->
  <div class="absolute inset-0 z-2" data-hero-shader></div>

  <!-- Canvas 2D: barely-visible random shapes that bounce and react to the cursor. -->
  <canvas class="absolute inset-0 z-5 pointer-events-none" data-hero-shapes></canvas>

  <!-- Legibility wash -->
  <div class="absolute inset-0 z-10 pointer-events-none hero-wash" aria-hidden="true"></div>

  <!-- Centered content -->
  <div class="relative z-30 flex min-h-dvh items-center justify-center px-6 md:px-12 text-center">
    <div class="max-w-3xl">
      <Kicker num="01" label="Engineering" />
      <h1 class="mt-6 display-tight text-5xl md:text-7xl lg:text-[96px] font-medium text-ivory-100">
        We turn ideas<br />
        into software.
      </h1>
      <p class="mt-8 text-onyx-200 max-w-xl mx-auto text-base md:text-lg leading-relaxed">
        A small team out of Addis Ababa building production systems for founders in London, Dallas, and Berlin.
      </p>
      <div class="mt-10 flex flex-wrap gap-3 justify-center">
        <Button
          href="mailto:contact@zaftech.co?subject=Start%20a%20project"
          variant="primary"
          data-ga-event="cta_click"
          data-ga-label="Hero - Start a project"
        >Start a project</Button>
        <Button
          href="/audit"
          variant="ghost"
          data-ga-event="cta_click"
          data-ga-label="Hero - Get free audit"
        >Get free audit</Button>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-wash {
    background:
      radial-gradient(ellipse at 50% 50%, rgba(12,15,13,0.2) 0%, rgba(12,15,13,0.55) 70%),
      linear-gradient(to bottom, rgba(12,15,13,0.5) 0%, rgba(12,15,13,0.25) 40%, rgba(12,15,13,0.7) 100%);
  }
  @media (prefers-color-scheme: light) {
    .hero-wash {
      background:
        radial-gradient(ellipse at 50% 50%, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0.55) 70%),
        linear-gradient(to bottom, rgba(255,255,255,0.5) 0%, rgba(255,255,255,0.25) 40%, rgba(255,255,255,0.7) 100%);
    }
  }
</style>

<script>
  /*
   * Hero: two synchronised canvases.
   *   1. WebGL (OGL): composed team bento, heavily blurred. A gray overlay covers
   *      everything; the cursor "shades it away" within uRadius so the blurred
   *      colour bleeds through, still blurred.
   *   2. Canvas 2D: sparse decorative shapes that bounce around the hero and are
   *      pushed away by the cursor within the same radius.
   * Both share the same mouse + radius state so the visual impact is cohesive.
   */

  import { Renderer, Program, Mesh, Triangle, Texture } from "ogl";

  type Palette = { grayTarget: number; darken: number };
  const DARK:  Palette = { grayTarget: 0.55, darken: 0.45 };
  const LIGHT: Palette = { grayTarget: 0.55, darken: 0.85 };

  // Shared cursor state. Both canvases read from this.
  const mouse = {
    targetX: 0.5, targetY: 0.5,
    x: 0.5,       y: 0.5,
    targetR: 0,   r: 0,
    hovering: false,
  };
  const HOVER_R = 0.24; // UV units on the shorter axis

  const vertex = /* glsl */ `
    attribute vec2 position;
    attribute vec2 uv;
    varying vec2 vUv;
    void main() { vUv = uv; gl_Position = vec4(position, 0.0, 1.0); }
  `;

    // Simplified shader: just blurs the background image.
    // The reveal lifts the gray/darkening overlay.
    const fragment = /* glsl */ `
    precision highp float;
    varying vec2 vUv;
    uniform sampler2D uTex;
    uniform vec2 uMouse;
    uniform float uRadius;
    uniform float uAspect;
    uniform float uImgAspect;
    uniform vec2 uTexelSize;
    uniform float uGray;
    uniform float uDarken;

    vec4 blurTex(vec2 uv, float r) {
      vec4 sum = vec4(0.0);
      float total = 0.0;
      for (int x = -1; x <= 1; x++) {
        for (int y = -1; y <= 1; y++) {
          vec2 off = vec2(float(x), float(y)) * uTexelSize * r;
          float w = exp(-float(x*x + y*y) / 2.0);
          sum += texture2D(uTex, uv + off) * w;
          total += w;
        }
      }
      return sum / total;
    }

    void main() {
      // object-cover UV transform so the shader samples the same crop
      // as the underlying <Image object-cover>. This prevents the visible
      // image from "snapping" to a different position once the shader appears.
      vec2 sUv = vUv;
      if (uImgAspect > uAspect) {
        float s = uAspect / uImgAspect;
        sUv.x = (vUv.x - 0.5) * s + 0.5;
      } else {
        float s = uImgAspect / uAspect;
        sUv.y = (vUv.y - 0.5) * s + 0.5;
      }

      vec4 blurred = blurTex(sUv, 2.5); // light blur — preserve image detail

      // Reveal mask works in canvas space (vUv), aspect-corrected so the
      // hover circle stays round regardless of viewport ratio.
      vec2 d = (vUv - uMouse) * vec2(uAspect, 1.0);
      float dist = length(d);
      float mask = 1.0 - smoothstep(uRadius * 0.55, uRadius, dist);

      float gray = dot(blurred.rgb, vec3(0.299, 0.587, 0.114));

      // Base state: fully gray + darkened.
      vec3 base = mix(blurred.rgb, vec3(gray), uGray) * uDarken;

      // Revealed state: keep the blur, lift the gray slightly.
      float revealGray   = uGray   * 0.15;
      float revealDarken = max(uDarken, 0.75);
      vec3 reveal = mix(blurred.rgb, vec3(gray), revealGray) * revealDarken;

      vec3 color = mix(base, reveal, mask);
      gl_FragColor = vec4(color, 1.0);
    }
  `;


    // Removed composeBento and related loadImage/drawCover functions

  async function startShader(hero: HTMLElement) {
    const hostEl = hero.querySelector<HTMLElement>("[data-hero-shader]");
    if (!hostEl) return;
    const host = hostEl;

    const themeQuery = window.matchMedia("(prefers-color-scheme: light)");
    
    // Set initial palette
    let palette: Palette = themeQuery.matches ? LIGHT : DARK;

    // Use the background image (resolved via Astro's asset pipeline) as the shader texture.
    const heroSrc = hero.dataset.heroSrc;
    if (!heroSrc) return;
    const img = new Image();
    img.decoding = "async";
    img.src = heroSrc;
    try {
      if (img.decode) await img.decode();
      else await new Promise<void>((res, rej) => {
        img.onload = () => res();
        img.onerror = () => rej(new Error("hero image failed to load"));
      });
    } catch {
      return;
    }
    // Use the image's natural dimensions so it's not pre-stretched. The
    // shader then re-crops via uImgAspect to match the visible <Image object-cover>.
    const imgW = img.naturalWidth || 1920;
    const imgH = img.naturalHeight || 1080;
    const bentoCanvas = document.createElement("canvas");
    bentoCanvas.width = imgW;
    bentoCanvas.height = imgH;
    const ctx = bentoCanvas.getContext("2d");
    if (!ctx) return;
    ctx.drawImage(img, 0, 0, imgW, imgH);

    const renderer = new Renderer({ alpha: true, dpr: Math.min(window.devicePixelRatio || 1, 2) });
    const gl = renderer.gl;
    gl.clearColor(0, 0, 0, 0);
    host.appendChild(gl.canvas);
    gl.canvas.style.display = "block";
    gl.canvas.style.width = "100%";
    gl.canvas.style.height = "100%";

    const texture = new Texture(gl, { generateMipmaps: false });
    texture.image = bentoCanvas as unknown as HTMLImageElement;


    const geometry = new Triangle(gl);
    const program = new Program(gl, {
      vertex,
      fragment,
      uniforms: {
        uTex:        { value: texture },
        uMouse:      { value: new Float32Array([0.5, 0.5]) },
        uRadius:     { value: 0.0 },
        uAspect:     { value: 1.0 },
        uImgAspect:  { value: imgW / imgH },
        uTexelSize:  { value: new Float32Array([1 / imgW, 1 / imgH]) },
        uGray:       { value: palette.grayTarget },
        uDarken:     { value: palette.darken },
      },
    });
    const mesh = new Mesh(gl, { geometry, program });

    function resize() {
      const rect = host.getBoundingClientRect();
      renderer.setSize(rect.width, rect.height);
      program.uniforms.uAspect.value = rect.width / Math.max(rect.height, 1);
    }
    resize();
    window.addEventListener("resize", resize);

    themeQuery.addEventListener("change", (e: MediaQueryListEvent) => {
      palette = e.matches ? LIGHT : DARK;
      program.uniforms.uGray.value = palette.grayTarget;
      program.uniforms.uDarken.value = palette.darken;
    });

    let visible = true;
    const visIo = new IntersectionObserver(
      (entries) => { visible = entries[0]?.isIntersecting ?? true; },
      { threshold: 0 }
    );
    visIo.observe(hero);

    function frame() {
      requestAnimationFrame(frame);
      if (!visible || document.hidden) return;
      program.uniforms.uMouse.value[0] = mouse.x;
      program.uniforms.uMouse.value[1] = 1.0 - mouse.y;
      program.uniforms.uRadius.value = mouse.r;
      renderer.render({ scene: mesh });
    }
    requestAnimationFrame(frame);
  }

  /* ============================================================
     Canvas 2D shapes: decorative particles that bounce + push.
     ============================================================ */
  type Shape = {
    x: number; y: number;   // pixel position within hero
    vx: number; vy: number; // velocity (px/s)
    size: number;
    rot: number; rotSpeed: number;
    type: "square" | "triangle" | "cross" | "circle" | "diag";
  };

  function startShapes(hero: HTMLElement) {
    const canvasEl = hero.querySelector<HTMLCanvasElement>("[data-hero-shapes]");
    if (!canvasEl) return;
    const ctxMaybe = canvasEl.getContext("2d");
    if (!ctxMaybe) return;
    const canvas = canvasEl;
    const ctx = ctxMaybe;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let width = 0, height = 0;
    let dpr = Math.max(1, Math.min(window.devicePixelRatio || 1, 2));

    function resize() {
      const rect = hero.getBoundingClientRect();
      width = rect.width; height = rect.height;
      dpr = Math.max(1, Math.min(window.devicePixelRatio || 1, 2));
      canvas.width = Math.round(width * dpr);
      canvas.height = Math.round(height * dpr);
      canvas.style.width = width + "px";
      canvas.style.height = height + "px";
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resize();
    window.addEventListener("resize", resize);

    const COUNT = 210;
    const TYPES: Shape["type"][] = ["square", "triangle", "cross", "circle", "diag"];
    const shapes: Shape[] = [];
    const rand = (min: number, max: number) => min + Math.random() * (max - min);

    for (let i = 0; i < COUNT; i++) {
      const angle = Math.random() * Math.PI * 2;
      const speed = rand(8, 28);
      shapes.push({
        x: Math.random() * width,
        y: Math.random() * height,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        size: rand(10, 34),
        rot: Math.random() * Math.PI * 2,
        rotSpeed: rand(-0.35, 0.35),
        type: TYPES[Math.floor(Math.random() * TYPES.length)],
      });
    }

    let visible = true;
    const io = new IntersectionObserver(
      (entries) => { visible = entries[0]?.isIntersecting ?? true; },
      { threshold: 0 }
    );
    io.observe(hero);

    let lastT = performance.now();

    function frame(now: number) {
      requestAnimationFrame(frame);
      const dt = Math.min((now - lastT) / 1000, 1 / 30);
      lastT = now;
      if (!visible || document.hidden || width === 0) return;

      ctx.clearRect(0, 0, width, height);

      // Cursor position in pixel space.
      const cx = mouse.x * width;
      const cy = mouse.y * height;
      // Impact radius. We aspect-correct uRadius (UV on shorter axis) back to pixels.
      const radiusPx = mouse.r * Math.min(width, height);

      for (const s of shapes) {
        // Cursor repulsion + brightness flare within the shader's same radius.
        let flare = 0;
        if (radiusPx > 0) {
          const dx = s.x - cx;
          const dy = s.y - cy;
          const dist = Math.hypot(dx, dy);
          if (dist < radiusPx) {
            const push = (1 - dist / radiusPx) * 220 * dt;
            const invD = dist > 0.001 ? 1 / dist : 0;
            s.vx += dx * invD * push;
            s.vy += dy * invD * push;
            flare = 1 - dist / radiusPx;
          }
        }

        // Gentle drag so impulses settle.
        if (!reduced) {
          s.vx *= 0.985;
          s.vy *= 0.985;
          s.x += s.vx * dt;
          s.y += s.vy * dt;
          s.rot += s.rotSpeed * dt;
        }

        // Bounce off hero edges.
        if (s.x < 0)           { s.x = 0;           s.vx = Math.abs(s.vx); }
        else if (s.x > width)  { s.x = width;       s.vx = -Math.abs(s.vx); }
        if (s.y < 0)           { s.y = 0;           s.vy = Math.abs(s.vy); }
        else if (s.y > height) { s.y = height;      s.vy = -Math.abs(s.vy); }

        // Render: noticeable by default, flares near the cursor.
        const baseAlpha = 0.3;
        const alpha = Math.min(baseAlpha + flare * 0.65, 0.95);

        ctx.save();
        ctx.translate(s.x, s.y);
        ctx.rotate(s.rot);
        ctx.strokeStyle = `rgba(127, 207, 179, ${alpha.toFixed(3)})`;
        ctx.lineWidth = 1.1 + flare * 0.9;

        const h = s.size / 2;
        switch (s.type) {
          case "square":
            ctx.strokeRect(-h, -h, s.size, s.size);
            break;
          case "triangle":
            ctx.beginPath();
            ctx.moveTo(0, -h);
            ctx.lineTo(h, h);
            ctx.lineTo(-h, h);
            ctx.closePath();
            ctx.stroke();
            break;
          case "cross":
            ctx.beginPath();
            ctx.moveTo(-h, 0); ctx.lineTo(h, 0);
            ctx.moveTo(0, -h); ctx.lineTo(0, h);
            ctx.stroke();
            break;
          case "circle":
            ctx.beginPath();
            ctx.arc(0, 0, h, 0, Math.PI * 2);
            ctx.stroke();
            break;
          case "diag":
            ctx.beginPath();
            ctx.moveTo(-h, -h); ctx.lineTo(h, h);
            ctx.stroke();
            break;
        }
        ctx.restore();
      }
    }
    requestAnimationFrame(frame);
  }

  /* ============================================================
     Shared cursor bookkeeping + scroll-in flash.
     ============================================================ */
  function startCursor(hero: HTMLElement) {
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function onMove(e: PointerEvent) {
      const rect = hero.getBoundingClientRect();
      mouse.targetX = (e.clientX - rect.left) / rect.width;
      mouse.targetY = (e.clientY - rect.top) / rect.height;
      mouse.hovering = true;
      mouse.targetR = HOVER_R;
    }
    function onLeave() {
      mouse.hovering = false;
      mouse.targetR = 0;
    }
    if (!reduced) {
      hero.addEventListener("pointermove", onMove, { passive: true });
      hero.addEventListener("pointerleave", onLeave);
    }

    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          mouse.targetR = 1.6;
          window.setTimeout(() => { if (!mouse.hovering) mouse.targetR = 0; }, 650);
          io.unobserve(hero);
        }
      },
      { threshold: 0.2 }
    );
    io.observe(hero);

    function tick() {
      requestAnimationFrame(tick);
      mouse.x += (mouse.targetX - mouse.x) * 0.12;
      mouse.y += (mouse.targetY - mouse.y) * 0.12;
      mouse.r += (mouse.targetR - mouse.r) * 0.1;
    }
    requestAnimationFrame(tick);
  }

  async function boot() {
    const heroEl = document.querySelector<HTMLElement>("[data-hero]");
    if (!heroEl) return;
    startCursor(heroEl);
    startShapes(heroEl);
    await startShader(heroEl);
  }

  const idle = (window as unknown as { requestIdleCallback?: (cb: () => void, opts?: { timeout: number }) => void }).requestIdleCallback;
  if (typeof idle === "function") idle(() => { void boot(); }, { timeout: 2000 });
  else setTimeout(() => { void boot(); }, 400);
</script>
