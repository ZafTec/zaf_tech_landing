---
import Kicker from "@/components/ui/Kicker.astro";

const channels = [
  { label: "Email",    value: "contact@zaftech.co", href: "mailto:contact@zaftech.co" },
  { label: "Location", value: "Addis Ababa, Ethiopia", href: null },
  { label: "Response", value: "Under 24 hours", href: null },
  { label: "GitHub",   value: "github.com/zaftech", href: "https://github.com/zaftech" },
];
---
<section id="contact" class="border-b border-onyx-800">
  <div class="px-6 md:px-12 py-24 md:py-28">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      <!-- Left: intro + direct channels -->
      <div class="lg:col-span-5 reveal-up">
        <Kicker num="09" label="Contact" />
        <h2 class="mt-4 display-tight text-3xl md:text-4xl font-medium text-ivory-100">
          Tell us what you're building.
        </h2>
        <p class="mt-5 text-onyx-300 text-base md:text-[17px] leading-relaxed max-w-md">
          A line or two is enough to start. We reply from a real mailbox, not a CRM.
        </p>

        <dl class="mt-10 space-y-5">
          {channels.map((c) => (
            <div class="grid grid-cols-[96px_1fr] items-baseline gap-4">
              <dt class="font-mono text-[10px] uppercase tracking-widest text-onyx-500">{c.label}</dt>
              <dd>
                {c.href ? (
                  <a
                    href={c.href}
                    class="text-ivory-100 hover:text-spruce-400 transition-colors"
                    {...(c.href.startsWith("http") ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                  >
                    {c.value}
                  </a>
                ) : (
                  <span class="text-ivory-100">{c.value}</span>
                )}
              </dd>
            </div>
          ))}
        </dl>
      </div>

      <!-- Right: form -->
      <form
        class="lg:col-span-7 border border-onyx-800 p-6 md:p-8 bg-onyx-950 reveal-up"
        style="--reveal-delay: 120ms;"
        data-contact-form
        method="post"
        action="/api/contact"
        novalidate
      >
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <label class="block">
            <span class="font-mono text-[10px] uppercase tracking-widest text-onyx-400">Name</span>
            <input
              type="text"
              name="name"
              required
              autocomplete="name"
              placeholder="Your name"
              class="mt-2 w-full bg-onyx-900 border border-onyx-800 text-ivory-100 placeholder-onyx-500/60 px-4 py-3"
            />
          </label>
          <label class="block">
            <span class="font-mono text-[10px] uppercase tracking-widest text-onyx-400">Email</span>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              inputmode="email"
              placeholder="you@company.com"
              class="mt-2 w-full bg-onyx-900 border border-onyx-800 text-ivory-100 placeholder-onyx-500/60 px-4 py-3"
            />
          </label>
        </div>

        <label class="block mt-5">
          <span class="font-mono text-[10px] uppercase tracking-widest text-onyx-400">What do you need?</span>
          <div class="relative">
            <select
              name="topic"
              required
              class="mt-2 w-full bg-onyx-900 border border-onyx-800 text-ivory-100 px-4 py-3 appearance-none cursor-pointer pr-10"
            >
              <option value="" disabled selected>Pick one</option>
              <option value="agency">Custom build (agency services)</option>
              <option value="convia">Convia question</option>
              <option value="mizan">Mizan question</option>
              <option value="rms">RMS question</option>
              <option value="anchor-talos">Anchor or Talos</option>
              <option value="other">Something else</option>
            </select>
            <svg class="absolute right-4 top-1/2 -translate-y-1/2 mt-1 text-onyx-400 pointer-events-none" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
        </label>

        <label class="block mt-5">
          <span class="font-mono text-[10px] uppercase tracking-widest text-onyx-400">Message</span>
          <textarea
            name="message"
            required
            rows="5"
            placeholder="A couple of sentences about the problem, timeline, or budget."
            class="mt-2 w-full bg-onyx-900 border border-onyx-800 text-ivory-100 placeholder-onyx-500/60 px-4 py-3 resize-none"
          ></textarea>
        </label>

        <div class="mt-6 flex flex-wrap items-center justify-between gap-4">
          <p class="font-mono text-[10px] uppercase tracking-widest text-onyx-500" data-contact-status>
            We reply in under 24 hours.
          </p>
          <button
            type="submit"
            class="btn-primary"
          >
            Send message
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const form = document.querySelector("[data-contact-form]");
    const status = document.querySelector("[data-contact-status]");
    if (!form || !status) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      status.textContent = "Sending...";
      const data = Object.fromEntries(new FormData(e.target));
      try {
        const res = await fetch("/api/contact", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });
        if (!res.ok) throw new Error(String(res.status));
        e.target.reset();
        status.textContent = "Message sent. We'll reply within 24 hours.";
      } catch {
        status.textContent = "Something went wrong. Email contact@zaftech.co and we'll follow up.";
      }
    });
  })();
</script>
