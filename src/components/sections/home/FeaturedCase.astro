---
import Button from "@/components/ui/Button.astro";
import Kicker from "@/components/ui/Kicker.astro";
import MetricTile from "@/components/ui/MetricTile.astro";
---
<section id="featured" class="border-b border-onyx-800 bg-onyx-900/30">
  <div class="px-6 md:px-12 py-24 md:py-32">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12">
      <div class="lg:col-span-7 reveal-up">
        <Kicker num="03" label="Case study · 2025" />
        <h2 class="mt-6 display-tight text-4xl md:text-5xl lg:text-6xl font-medium text-ivory-100">
          AfroChat scaled to 2,000 users <br class="hidden md:block" />
          on an infrastructure we cut <span class="text-spruce-400">73%</span> from.
        </h2>
        <p class="mt-6 text-onyx-300 max-w-xl text-base md:text-lg leading-relaxed">
          Four engineers. Fourteen weeks. A cost curve that was about to kill a product, replaced with one that the team could actually plan around.
        </p>
        <div class="mt-10">
          <Button href="/portfolio/afrochat" variant="ghost">Read the case study</Button>
        </div>
      </div>

      <div class="lg:col-span-5 grid grid-cols-2 gap-px bg-onyx-800 border border-onyx-800 self-start reveal-up" style="--reveal-delay: 120ms;">
        <div class="bg-onyx-950"><MetricTile value="2,341" label="Daily users" trend="up" /></div>
        <div class="bg-onyx-950"><MetricTile value="73%" label="Cost reduction" trend="down" /></div>
        <div class="bg-onyx-950"><MetricTile value="14 wk" label="Weeks to ship" trend="flat" /></div>
        <div class="bg-onyx-950"><MetricTile value="0.5s" label="Avg response" trend="down" /></div>
      </div>
    </div>
  </div>
</section>
