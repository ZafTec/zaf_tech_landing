---
interface NavItem {
  label: string;
  href: string;
  current?: boolean;
}

interface Props {
  nav?: NavItem[];
  variant?: "solid" | "transparent";
}

const {
  nav = [
    { label: "Services", href: "/services" },
    { label: "Products", href: "/#products" },
    { label: "Portfolio", href: "/#portfolio" },
    { label: "Contact", href: "/#contact" },
  ],
  variant = "solid",
} = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
---
<header
  class:list={[
    "fixed top-0 left-0 w-full z-50 border-b border-onyx-700",
    variant === "solid" ? "bg-onyx-950/95 backdrop-blur-sm" : "bg-transparent",
  ]}
  data-header
>
  <div class="px-6 md:px-12 py-4 flex items-center justify-between">
    <div class="flex items-center gap-6">
      <a href="/" class="flex items-center" aria-label="ZafTech home">
        <picture>
          <source srcset="/logo/ZAFTECH_LOGO_Square_bgremoved_dark_theme.png" media="(prefers-color-scheme: light)" />
          <img src="/logo/ZAFTECH_LOGO_Square_bgremoved_light_theme.png" alt="ZafTech Solutions" class="h-12 w-auto" width="48" height="48" />
        </picture>
      </a>
      <div class="hidden md:block h-4 w-px bg-onyx-700"></div>
      <nav class="hidden md:flex gap-6" aria-label="Primary">
        {nav.map((item) => {
          const isCurrent = item.current ?? (item.href === pathname);
          return (
            <a
              class:list={[
                "text-[10px] font-mono transition-colors uppercase tracking-widest",
                isCurrent ? "text-spruce-400" : "text-onyx-400 hover:text-spruce-400",
              ]}
              href={item.href}
              aria-current={isCurrent ? "page" : undefined}
            >
              {item.label}
            </a>
          );
        })}
      </nav>
    </div>
    <div class="flex items-center gap-4">
      <a
        href="/#contact"
        class="hidden sm:flex h-9 items-center justify-center px-5 bg-spruce-400 text-onyx-950 text-[10px] font-bold tracking-wider hover:bg-spruce-300 transition-colors uppercase"
      >
        Book a call
      </a>
      <button
        class="flex sm:hidden h-9 w-9 items-center justify-center bg-onyx-900 border border-onyx-700 text-ivory-100"
        data-mobile-menu
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu -->
<div class="fixed inset-0 z-40 pointer-events-none" data-mobile-menu-overlay>
  <div class="absolute inset-0 bg-onyx-950/80 opacity-0 transition-opacity duration-300 pointer-events-none" data-mobile-menu-backdrop></div>
  <nav class="absolute top-0 right-0 h-full w-64 bg-onyx-900 border-l border-onyx-700 transform translate-x-full transition-transform duration-300" data-mobile-menu-panel aria-label="Mobile">
    <div class="p-6 flex flex-col gap-6">
      <div class="flex justify-between items-center">
        <span class="text-xs font-mono text-onyx-400 uppercase tracking-widest">Menu</span>
        <button class="h-9 w-9 flex items-center justify-center text-ivory-100 hover:text-spruce-400 transition-colors" data-mobile-menu-close aria-label="Close menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div class="flex flex-col gap-4">
        {nav.map((item) => (
          <a
            class="text-sm font-mono text-ivory-100 hover:text-spruce-400 transition-colors uppercase tracking-wider py-2 border-b border-onyx-700"
            href={item.href}
            data-mobile-nav
          >
            {item.label}
          </a>
        ))}
        <a
          href="/#contact"
          class="mt-4 h-11 flex items-center justify-center px-5 bg-spruce-400 text-onyx-950 text-xs font-bold tracking-wider hover:bg-spruce-300 transition-colors uppercase"
          data-mobile-nav
        >
          Book a call
        </a>
      </div>
    </div>
  </nav>
</div>

<script is:inline>
  (function () {
    const btn = document.querySelector("[data-mobile-menu]");
    const close = document.querySelector("[data-mobile-menu-close]");
    const overlay = document.querySelector("[data-mobile-menu-overlay]");
    const backdrop = document.querySelector("[data-mobile-menu-backdrop]");
    const panel = document.querySelector("[data-mobile-menu-panel]");
    const links = Array.from(document.querySelectorAll("[data-mobile-nav]"));

    if (!btn || !overlay || !backdrop || !panel) return;

    const open = () => {
      overlay.classList.remove("pointer-events-none");
      backdrop.classList.remove("pointer-events-none", "opacity-0");
      panel.classList.remove("translate-x-full");
      btn.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
    };
    const hide = () => {
      overlay.classList.add("pointer-events-none");
      backdrop.classList.add("pointer-events-none", "opacity-0");
      panel.classList.add("translate-x-full");
      btn.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
    };

    btn.addEventListener("click", open);
    close?.addEventListener("click", hide);
    backdrop.addEventListener("click", hide);
    links.forEach((l) => l.addEventListener("click", hide));
  })();
</script>
