---
interface Props { class?: string; }
const { class: extra = "" } = Astro.props;
---
<svg viewBox="0 0 960 400" class:list={["w-full h-auto", extra]} fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="AfroChat architecture">
  <defs>
    <pattern id="arch-grid" x="0" y="0" width="24" height="24" patternUnits="userSpaceOnUse">
      <circle cx="1" cy="1" r="0.7" fill="var(--color-onyx-800)" />
    </pattern>
  </defs>
  <rect width="960" height="400" fill="url(#arch-grid)" />

  <!-- Web -->
  <g transform="translate(40,80)">
    <rect width="160" height="70" stroke="var(--color-onyx-700)" fill="var(--color-onyx-950)" />
    <text x="16" y="28" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="1.5" fill="var(--color-spruce-400)">// WEB</text>
    <text x="16" y="50" font-family="Geist, Inter, sans-serif" font-size="14" fill="var(--color-ivory-100)">React + Vite</text>
  </g>

  <!-- API -->
  <g transform="translate(280,80)">
    <rect width="160" height="70" stroke="var(--color-onyx-700)" fill="var(--color-onyx-950)" />
    <text x="16" y="28" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="1.5" fill="var(--color-spruce-400)">// API</text>
    <text x="16" y="50" font-family="Geist, Inter, sans-serif" font-size="14" fill="var(--color-ivory-100)">Go · 2 replicas</text>
  </g>

  <!-- Workers -->
  <g transform="translate(520,80)">
    <rect width="160" height="70" stroke="var(--color-onyx-700)" fill="var(--color-onyx-950)" />
    <text x="16" y="28" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="1.5" fill="var(--color-spruce-400)">// WORKERS</text>
    <text x="16" y="50" font-family="Geist, Inter, sans-serif" font-size="14" fill="var(--color-ivory-100)">Python · GPU pool</text>
  </g>

  <!-- Cache -->
  <g transform="translate(760,80)">
    <rect width="160" height="70" stroke="var(--color-onyx-700)" fill="var(--color-onyx-950)" />
    <text x="16" y="28" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="1.5" fill="var(--color-spruce-400)">// CACHE</text>
    <text x="16" y="50" font-family="Geist, Inter, sans-serif" font-size="14" fill="var(--color-ivory-100)">Redis cluster</text>
  </g>

  <!-- Lines row 1 to row 2 -->
  <path d="M120 150 L 120 220" stroke="var(--color-onyx-700)" stroke-dasharray="2 4" />
  <path d="M360 150 L 360 220" stroke="var(--color-onyx-700)" stroke-dasharray="2 4" />
  <path d="M600 150 L 600 220" stroke="var(--color-onyx-700)" stroke-dasharray="2 4" />
  <path d="M840 150 L 840 220" stroke="var(--color-onyx-700)" stroke-dasharray="2 4" />

  <!-- Postgres -->
  <g transform="translate(160,220)">
    <rect width="200" height="70" stroke="var(--color-onyx-700)" fill="var(--color-onyx-950)" />
    <text x="16" y="28" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="1.5" fill="var(--color-spruce-400)">// POSTGRES</text>
    <text x="16" y="50" font-family="Geist, Inter, sans-serif" font-size="14" fill="var(--color-ivory-100)">Primary + replica</text>
  </g>

  <!-- pgvector -->
  <g transform="translate(440,220)">
    <rect width="200" height="70" stroke="var(--color-spruce-400)" fill="var(--color-onyx-950)" />
    <text x="16" y="28" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="1.5" fill="var(--color-spruce-400)">// PGVECTOR</text>
    <text x="16" y="50" font-family="Geist, Inter, sans-serif" font-size="14" fill="var(--color-ivory-100)">RAG corpus</text>
  </g>

  <!-- Object store -->
  <g transform="translate(720,220)">
    <rect width="200" height="70" stroke="var(--color-onyx-700)" fill="var(--color-onyx-950)" />
    <text x="16" y="28" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="1.5" fill="var(--color-spruce-400)">// S3</text>
    <text x="16" y="50" font-family="Geist, Inter, sans-serif" font-size="14" fill="var(--color-ivory-100)">Attachments</text>
  </g>

  <!-- Bottom rail -->
  <rect x="40" y="330" width="880" height="36" stroke="var(--color-onyx-800)" fill="var(--color-onyx-900)" />
  <text x="56" y="354" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="1.5" fill="var(--color-onyx-400)">AWS eu-central-1  ·  Terraform  ·  GitHub Actions  ·  Prometheus + Grafana</text>
</svg>
