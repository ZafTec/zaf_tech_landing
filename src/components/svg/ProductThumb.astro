---
interface Props {
  product: "convia" | "mizan" | "rms" | "anchor" | "talos";
  class?: string;
}
const { product, class: extra = "" } = Astro.props;
---
<svg viewBox="0 0 480 280" class:list={["w-full h-auto", extra]} fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label={`${product} preview`}>
  <rect width="480" height="280" fill="var(--color-onyx-900)" />
  <rect x="0.5" y="0.5" width="479" height="279" fill="none" stroke="var(--color-onyx-800)" />

  {product === "convia" && (
    <g>
      <!-- form builder: single question with progress bar -->
      <text x="40" y="90" font-family="Geist, Inter, sans-serif" font-size="26" font-weight="500" fill="var(--color-ivory-100)">How did you</text>
      <text x="40" y="120" font-family="Geist, Inter, sans-serif" font-size="26" font-weight="500" fill="var(--color-spruce-400)">hear about us?</text>
      <line x1="40" y1="160" x2="360" y2="160" stroke="var(--color-onyx-700)" />
      <rect x="40" y="220" width="400" height="3" fill="var(--color-onyx-800)" />
      <rect x="40" y="220" width="240" height="3" fill="var(--color-spruce-400)" />
      <text x="40" y="245" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="1.5" fill="var(--color-onyx-400)">3 OF 5</text>
      <circle cx="420" cy="221" r="4" fill="var(--color-spruce-400)" />
    </g>
  )}

  {product === "mizan" && (
    <g>
      <!-- nutrition: plate + line chart -->
      <circle cx="100" cy="140" r="60" stroke="var(--color-onyx-700)" stroke-width="1" />
      <circle cx="100" cy="140" r="50" stroke="var(--color-onyx-800)" stroke-width="1" />
      <path d="M60 140 A 40 40 0 0 1 140 140" fill="var(--color-spruce-400)" opacity="0.2" />
      <path d="M100 100 A 40 40 0 0 1 132 160" stroke="var(--color-spruce-400)" stroke-width="1" fill="none" />
      <!-- calorie trend chart -->
      <polyline points="210,200 250,180 290,190 330,160 370,170 410,140 440,150" stroke="var(--color-spruce-400)" stroke-width="1.5" fill="none" />
      <line x1="210" y1="220" x2="440" y2="220" stroke="var(--color-onyx-700)" />
      <text x="210" y="80" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="1.5" fill="var(--color-onyx-400)">TODAY</text>
      <text x="210" y="105" font-family="Geist, Inter, sans-serif" font-size="28" fill="var(--color-ivory-100)" font-weight="500">1,847 kcal</text>
    </g>
  )}

  {product === "rms" && (
    <g>
      <!-- tablet POS -->
      <rect x="60" y="40" width="360" height="200" rx="6" stroke="var(--color-onyx-700)" />
      <line x1="60" y1="80" x2="420" y2="80" stroke="var(--color-onyx-800)" />
      <rect x="80" y="100" width="80" height="60" stroke="var(--color-onyx-700)" />
      <rect x="180" y="100" width="80" height="60" stroke="var(--color-onyx-700)" />
      <rect x="280" y="100" width="80" height="60" stroke="var(--color-spruce-400)" />
      <rect x="80" y="180" width="80" height="40" stroke="var(--color-onyx-700)" />
      <rect x="180" y="180" width="80" height="40" stroke="var(--color-onyx-700)" />
      <rect x="280" y="180" width="80" height="40" stroke="var(--color-onyx-700)" />
      <text x="80" y="70" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="1.5" fill="var(--color-spruce-400)">TABLE 04</text>
    </g>
  )}

  {product === "anchor" && (
    <g>
      <!-- docs → vectors → answer -->
      <g transform="translate(40,80)">
        <rect width="80" height="100" stroke="var(--color-onyx-700)" />
        <line x1="12" y1="16" x2="68" y2="16" stroke="var(--color-onyx-700)" />
        <line x1="12" y1="30" x2="68" y2="30" stroke="var(--color-onyx-700)" />
        <line x1="12" y1="44" x2="50" y2="44" stroke="var(--color-onyx-700)" />
        <line x1="12" y1="58" x2="68" y2="58" stroke="var(--color-onyx-700)" />
        <line x1="12" y1="72" x2="40" y2="72" stroke="var(--color-onyx-700)" />
      </g>
      <path d="M130 130 L 200 130" stroke="var(--color-onyx-600)" stroke-dasharray="2 3" />
      <g transform="translate(210,90)">
        <circle cx="30" cy="30" r="30" stroke="var(--color-spruce-400)" />
        <text x="30" y="35" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="var(--color-spruce-400)">RAG</text>
      </g>
      <path d="M280 130 L 340 130" stroke="var(--color-onyx-600)" stroke-dasharray="2 3" />
      <g transform="translate(350,100)">
        <rect width="100" height="60" stroke="var(--color-onyx-700)" />
        <line x1="10" y1="15" x2="90" y2="15" stroke="var(--color-onyx-700)" />
        <line x1="10" y1="28" x2="70" y2="28" stroke="var(--color-onyx-700)" />
        <line x1="10" y1="41" x2="80" y2="41" stroke="var(--color-onyx-700)" />
        <text x="10" y="55" font-family="JetBrains Mono, monospace" font-size="8" fill="var(--color-spruce-400)">94% ACCURACY</text>
      </g>
    </g>
  )}

  {product === "talos" && (
    <g>
      <!-- shield with terminal inside -->
      <path d="M240 40 L 140 80 L 140 160 C 140 200, 190 230, 240 250 C 290 230, 340 200, 340 160 L 340 80 Z" stroke="var(--color-onyx-700)" />
      <rect x="170" y="110" width="140" height="90" stroke="var(--color-onyx-800)" fill="var(--color-onyx-950)" />
      <text x="180" y="128" font-family="JetBrains Mono, monospace" font-size="9" fill="var(--color-onyx-400)">$ talos run</text>
      <text x="180" y="144" font-family="JetBrains Mono, monospace" font-size="9" fill="var(--color-spruce-400)">&gt; sandbox ready</text>
      <text x="180" y="160" font-family="JetBrains Mono, monospace" font-size="9" fill="var(--color-onyx-400)">&gt; jwt verified</text>
      <text x="180" y="176" font-family="JetBrains Mono, monospace" font-size="9" fill="var(--color-onyx-400)">&gt; exit 0 (42ms)</text>
    </g>
  )}
</svg>
