---
const year = new Date().getFullYear();

const columns = [
  {
    title: "Services",
    links: [
      { label: "Full-stack engineering", href: "/services#backend" },
      { label: "AI & LLM integration", href: "/services#ml-ai" },
      { label: "Cloud & DevOps", href: "/services#cloud" },
      { label: "UI/UX & frontend", href: "/services#frontend" },
      { label: "All services", href: "/services" },
    ],
  },
  {
    title: "Products",
    links: [
      { label: "Convia", href: "/products/convia" },
      { label: "Mizan", href: "https://mizan.zaftech.co" },
      { label: "Anchor", href: "https://anchor.zaftech.co" },
      { label: "Talos", href: "https://talos.zaftech.co" },
      { label: "All products", href: "/#products" },
    ],
  },
  {
    title: "Company",
    links: [
      { label: "About", href: "/#about" },
      { label: "Careers", href: "/careers" },
      { label: "Contact", href: "/#contact" },
      { label: "GitHub", href: "https://github.com/zaftech" },
    ],
  },
  {
    title: "Legal",
    links: [
      { label: "Terms of Service", href: "/terms" },
      { label: "Privacy Policy", href: "/privacy" },
      { label: "Refund Policy", href: "/refunds" },
      { label: "Cookie Policy", href: "/cookies" },
      { label: "Acceptable Use", href: "/acceptable-use" },
    ],
  },
];
---
<footer class="border-t border-onyx-700 bg-onyx-950 mt-auto">
  <div class="max-w-6xl mx-auto px-6 md:px-12 py-12 md:py-16">
    <div class="grid grid-cols-2 md:grid-cols-6 gap-8 md:gap-12">
      <div class="col-span-2 md:col-span-2">
        <a href="/" class="flex items-center gap-3" aria-label="ZafTech home">
          <picture>
            <source srcset="/logo/ZAFTECH_LOGO_Square_bgremoved_dark_theme.png" media="(prefers-color-scheme: light)" />
            <img src="/logo/ZAFTECH_LOGO_Square_bgremoved_light_theme.png" alt="ZafTech Solutions" class="h-10 w-auto" width="40" height="40" />
          </picture>
          <span class="font-mono text-xs uppercase tracking-widest text-onyx-300">ZafTech</span>
        </a>
        <p class="mt-4 text-sm text-onyx-400 leading-relaxed max-w-xs">
          Production-grade software for teams that can't afford to be wrong. Based in Addis Ababa, shipping globally.
        </p>
        <p class="mt-6 font-mono text-[10px] uppercase tracking-widest text-onyx-500">
          Addis Ababa, Ethiopia
        </p>
        <a href="mailto:contact@zaftech.co" class="mt-1 inline-block font-mono text-[10px] tracking-wider text-onyx-400 hover:text-spruce-400 transition-colors">
          contact@zaftech.co
        </a>
      </div>

      {columns.map((col) => (
        <div>
          <h3 class="font-mono text-[10px] uppercase tracking-widest text-spruce-400 mb-4">{col.title}</h3>
          <ul class="space-y-3">
            {col.links.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="text-sm text-onyx-300 hover:text-spruce-400 transition-colors"
                  {...(l.href.startsWith("http") ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                >
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-8 border-t border-onyx-800 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 text-[10px] font-mono text-onyx-500 uppercase tracking-widest">
      <span>&copy; {year} ZafTech Solutions. All rights reserved.</span>
      <span>Built in Astro. Open source on <a class="hover:text-spruce-400 transition-colors" href="https://github.com/zaftech" target="_blank" rel="noopener noreferrer">GitHub</a>.</span>
    </div>
  </div>
</footer>
